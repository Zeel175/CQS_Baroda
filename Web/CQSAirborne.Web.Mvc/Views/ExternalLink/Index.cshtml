
@{

    ViewData["Title"] = "ExternalLink";
    ViewData["PageHeader"] = "ExternalLink";
    ViewData["CurrentPage"] = "ExternalLink";
}


<div class="row">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header card-header-primary card-header-container">
                <h4 class="card-title">External Link List</h4>
                <div class="card-header-actions">
                    <a href='@Url.Action("Create","ExternalLink")' class="btn btn-warning">
                        <i class="fa fa-plus"></i>
                        Add New
                    </a>
                </div>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table id="example" class="table table-striped table-bordered nowrap" cellspacing="0" width="100%">
                        <thead class="text-primary">
                            <tr>
                                <th>Link Name</th>
                                <th>URL</th>
                                <th>Priority</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
        var dataUrl = '@Url.Action("GetExternalLinkData", "ExternalLink")';
</script>
<script>
    var grid;
    $(document).ready(function () {
        grid = $('#example').DataTable({
            "searching": false,
            "processing": true,
            "serverSide": true,
            "columns": [
                //{ "data": "code" },
                { "data": "name" },
                { "data": "priority" },
                { "data": "url" },

                {
                    "data": null,
                    "mRender": function (data, type, row) {
                        return "<a href='/ExternalLink/Edit/" + row.id +"'> <i class='fa fa-pencil'></i></a>"
                    },
                    "searchable": false,
                    "orderable": false,
                    "className": "center-content"
                }
            ],
            "ajax": {
                "url": dataUrl,
                "type": "POST",
                "error": function (xhr, error, code) {
                    //debugger;
                    if (code == "Unauthorized") {
                        Swal.fire({
                            title: 'Session Expired!',
                            icon: 'error',
                            showCancelButton: false,
                            confirmButtonColor: '#3085d6',
                            confirmButtonText: 'Ok',
                            allowEscapeKey: true
                        }).then((result) => {
                            if (result.value) {
                                logoutWeb('@Url.Action("LogOut", "Account")');
                            }
                            if (result.dismiss === Swal.DismissReason.timer) {
                                logoutWeb('@Url.Action("LogOut", "Account")');
                            }
                        })
                    }
                }
            }
        });
    });
</script>



