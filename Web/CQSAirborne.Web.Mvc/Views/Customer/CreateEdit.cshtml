        debugger;
        $("#spinner").hide();
    }

    function CopySelectedText(e) {
        //debugger;

        var copyText = $(e).attr('href');

        document.addEventListener('copy', function (e) {
            e.clipboardData.setData('text/plain', copyText);
            e.preventDefault();
        }, true);

        document.execCommand('copy');
        console.log('copied text : ', copyText);
        toastr.success('Copied Text!!');
        return false;
    }

    $('.copy_text').click(function (e) {
        e.preventDefault();
        var copyText = $(this).attr('href');

        document.addEventListener('copy', function (e) {
            e.clipboardData.setData('text/plain', copyText);
            e.preventDefault();
        }, true);

        document.execCommand('copy');
        console.log('copied text : ', copyText);
        toastr.success('Copied Text!!');
    });

    function RemoveRowAndHideHeaderGenuine(id) {
        var $table = $(id).parents("table");
        var pictureid = $(id).closest("tr").data("attid");
        var documentid = $(id).closest("tr").data("documentid");
        var customerid = $('#Id').val();

        $(id).closest("tr").remove();
        Delete(pictureid, documentid, customerid);
        if ($table.find("tbody").find("tr").length == 0) {
            $table.parent().addClass("hidden");
        }
    }

    $("#AddAttach").click(function () {
        $("#idErrorMessage").val("");
        var Name = $("#DocumentId");
        var Attachment = $("#PictureId");
        var startDate = $('#StartDate').val();
        var endDate = $('#EndDate').val();

        if (Name.val() == "") {
            $("#idErrorMessage").text('Document is Required.');
        }
        else {
            //Name.siblings('span').html('');
        }
        if (Attachment.val() == "") {
            $("#idErrorMessage").text('Attachment is Required.');
        }
        else {
            //Attachment.siblings('span').html('');
        }

        if ($('#StartDate').val() == "") {
            $("#idErrorMessage").text('Start date is required.');
        }
        else {
            //$('#StartDate').siblings('span').html('');
        }

        if ($('#EndDate').val() == "") {
            $("#idErrorMessage").text('End date is required.');
        }
        else {
            //$('#EndDate').siblings('span').html('');
        }

        if (Name.val() == "" || Attachment.val() == "" || $('#StartDate').val() == "" || $('#EndDate').val() == "") {
            return false;
        }

        $("#spinner").show();


        $("#DocumentDetail").parent().removeClass("hidden");

        $("#AddAttach").attr('disabled', 'disabled');

        debugger;
        var obj = {
            CustomerId: $('#Id').val(),
            DocumentId: Name.val(),
            PictureId: Attachment.val(),
            Path: "",
            StartDate: startDate,
            EndDate: endDate,
        };
        var createdLink = '';
         $.post("@Url.Action("CreateEditCustomerDocument", "Customer")", obj,
            function (data) {
                debugger;
                if (data != null && data != undefined && data != '') {
                    try {
                        createdLink = data;


                        $("#DocumentDetail > tbody").append("<tr data-documentid='" +
                            Name.val() + "' data-documentname='" + $("#DocumentId").data("kendoDropDownList").dataItem().name + "' data-attid='" + Attachment.val() + "' data-attname='" + $("#PictureId").data("kendoDropDownList").dataItem().name + "' data-startdate='" + startDate + "' data-enddate='" + endDate + "' data-createdlink='" + createdLink + "'><td style='vertical-align: middle;'>" +
                            $("#DocumentId").data("kendoDropDownList").dataItem().name + "</td><td style='vertical-align: middle;'>" + $("#PictureId").data("kendoDropDownList").dataItem().name + "</td>" +
                            "<td style='vertical-align: middle;'>" + startDate + "</td>" +
                            "<td style='vertical-align: middle;'>" + endDate + "</td>" +
                            "<td style='text-align: center;vertical-align: middle;'><a style='cursor:pointer !important;padding: 9px;' onclick='return CopySelectedText(this)' href='" + createdLink + "' class='btn btn-primary ' >Copy Link</td>" +
                            "<td style='text-align: center;vertical-align: middle;'><a onClick='RemoveRowAndHideHeaderGenuine(this);' class='text-danger' ><span class='fa fa-remove'></span></a></td></tr>");

        //$("#DocumentId").val('');

                        $("#PictureId").val('Select Attachment..');
                } catch { }

            }
            else {
                alert("Something Went Wrong!");
                }

                $("#AddAttach").removeAttr("disabled");
                $("#spinner").hide();
        });


        $("#DocumentId").focus();


    });


    function Delete(pictureid, documentid, customerid) {
        $.post("@Url.Action("DeleteCustomerDocument", "Customer")", { pictureid: pictureid, documentid: documentid, customerid: customerid },
            function (data) {
                //debugger;

                    toastr.success("Deleted!!");
        })
    };

    function checkValidation() {
        var $PageValid = true;
        BuildNativeTables();
        $("#IsSendEmail").val(false);
        return $PageValid;
    }

    function BuildNativeTables() {

        var listName = "CustomerDocumentDetail";
        qtd = 0;
        $("#DocumentDetail > tbody > tr").each(function () {
            var docId = $(this).data("documentid");
            var attId = $(this).data("attid");
            var startDate = $(this).data("startdate");
            var endDate = $(this).data("enddate");
            var createdLink = $(this).data("createdlink");

            $("#CreateEditCustomerForm").prepend("<input type='hidden' name='" + listName + "[" + qtd + "].DocumentId' value='" + docId + "'>");
            $("#CreateEditCustomerForm").prepend("<input type='hidden' name='" + listName + "[" + qtd + "].PictureId' value='" + attId + "'>");
            $("#CreateEditCustomerForm").prepend("<input type='hidden' name='" + listName + "[" + qtd + "].StartDate' value='" + startDate + "'>");
            $("#CreateEditCustomerForm").prepend("<input type='hidden' name='" + listName + "[" + qtd + "].EndDate' value='" + endDate + "'>");
            $("#CreateEditCustomerForm").prepend("<input type='hidden' name='" + listName + "[" + qtd + "].CreatedLink' value='" + createdLink + "'>");

            qtd += 1;
        });
    }


    $("#Email").on('beforeItemAdd', function (event) {
        //debugger
        // check item contents
        if (!/^[a-zA-Z0-9.!#$%&'*+/=?^_`{|}~-]+@@[a-zA-Z0-9-]+(?:\.[a-zA-Z0-9-]+)*$/.test(event.item)) {
            // set to true to prevent the item getting added
            event.cancel = true;
        }
    });

    var isEmail = false;
    $("#btnCustomerEmail").click(function () {
        toastr.success("Please Wait....");
        isEmail = true;
        var $PageValid = true;
        BuildNativeTables();
        $("#IsSendEmail").val(true);
    })

    //debugger;
    var today = new Date();
    var setdt = new Date(today.setDate(today.getDate() + 90))
    $("#EndDate").kendoDatePicker({
        max: setdt,
        format: "dd-MMM-yyyy"
    });

</script>
