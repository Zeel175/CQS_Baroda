@using CQSAirborne.Web.Infrastructure.Helpers.DropZone
@using CQSAirborne.Web.Infrastructure.Helpers.Dropdown
@using CQSAirborne.Web.Infrastructure.Helpers.DatePicker
@using CQSAirborne.Web.Infrastructure.Helpers.Editor

@model CQSAirborne.Model.Customer.AddEditCustomerModel;
@{
    ViewData["Title"] = "Create/Edit Customer";
}

<link href="~/Vendor/Jquery-Popup/css/popup.css" rel="stylesheet" />
@(await Html.PartialAsync("~/Views/Shared/Components/PopupWindow/_PopupWindowPartial.cshtml"))

<script>

    function onDocumentChange(data) {
        $("#idAttachment").hide();
        $("#PictureId").val("");
        var dataUrl = '@Url.Action("GetAllAttachmentListByDocumentId", "Document")';
       // var categoryElement = $("#PictureId").data("kendoDropDownList");
        var document = $("#DocumentId").data("kendoDropDownList");
        var docId = $("#DocumentId").val();
        if (docId != null && docId > 0) {
            $("#idAttachment").show();
            $.get(dataUrl + "?Id=" + $("#DocumentId").val(), function (data) {


                var parameter = $("#PictureId").kendoDropDownList({
                    optionLabel: "Select Attachment..",
                    dataTextField: "name",
                    dataValueField: "id",
                    autoBind: false,
                    dataSource: data
                }).data("kendoDropDownList");


                if (data.length > 0) {                    setTimeout(() => {
                        parameter.value(data[0].id);
                    }, 1000)
                }
                else {
                    $("#PictureId").val("");
                }
            })
        }
        else {
            $("#PictureId").val("");
        }
    }

</script>
<style>
    .input-validation-error {
        border: none !important;
        border-bottom: 1px solid #dc3545 !important
    }
</style>
<div class="row">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header card-header-primary card-header-container">
                <h4 class="card-title ">Manage Customer</h4>
            </div>
            <div class="card-body">
                <form asp-action="CreateEdit" asp-controller="Customer" data-ajax="true" id="CreateEditCustomerForm" data-ajax-method="POST" data-ajax-success="onSuccess" data-ajax-failure="onFailed" data-ajax-loading="#spinner" data-ajax-complete="onComplete">
                    <div class="validation-summary-errors" id="ModelStateError"></div>
                    @Html.AntiForgeryToken()

                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="IsSendEmail" />

                    <div class="form-row" style="margin-top:15px;">
                        <div class="col-6">
                            <div class="form-group">
                                <label class="form-control-label">Customer Name</label>
                                <input type="text" asp-for="CustomerName" class="form-control" />
                                <span asp-validation-for="CustomerName" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="form-group">
                                <label class="form-control-label">Contact Number</label>
                                <input type="number" asp-for="ContactNumber" maxlength="10" class="form-control" />
                                @*<span asp-validation-for="ContactNumber" class="text-danger"></span>*@
                            </div>
                        </div>
                    </div>
                    <div class="form-row">
                        <div class="col-6">
                            <div class="form-group">
                                <label class="form-control-label">Email</label>
                                <input type="email" asp-for="Email" class="form-control tagsinput" data-role="tagsinput" />
                                <span asp-validation-for="Email" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="form-group">
                                <label class="form-control-label">Password</label>
                                <input type="text" asp-for="Password" maxlength="10" class="form-control ignoreKeyPress" />
                                <span asp-validation-for="Password" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    @if (Model.Id != null && Model.Id != 0)
                    {
                        <div class="row form-group">
                            <div class="col-md-12">
                                <h4 style="font-weight: bold;color: #00bcd4;font-size: 20px;margin-left: -15px;">Customer Document Mapping</h4>
                            </div>
                        </div>
                        <hr style="margin-top: 0px !important;" />

                        <div class="form-row">
                            <div class="col-md-3">
                                @Html.LabelFor(w => w.DocumentId)
                                @(Html.KendoDropDownListFor(w => w.DocumentId)
                                            .Read(Url.Action("GetAllDocumentList", "Document"))
                                            .DataTextField("name")
                                            .DataValueField("id")
                                            .OptionLabel("Select Document..")
                                            .OnChange("onDocumentChange")
                                            .Filter("Contains")
                                            .HtmlAttributes(new { @class = "form-control", style = "width: 100%" })
                                            .Render())
                            </div>
                            <div class="col-md-3" id="idAttachment" style="display:none;width:100%">
                                @Html.LabelFor(w => w.PictureId)<br />
                                @(Html.KendoDropDownListFor(w => w.PictureId)
                                                                                                                                                        //.Read(Url.Action("GetAllDocumentList", "Document"))
                                                                                                                                                        //.DataTextField("name")
                                                                                                                                                        //.DataValueField("id")
                                                                                                                                                        //.OptionLabel("Select Document..")
                                                                                                                                                        //.OnChange("onDocumentChange")
                                                                                                                                                        //.HtmlAttributes(new { @class = "form-control", style = "width: 100%" })
                                                                                                                                                        .Render())
                            </div>
                            <div class="col-md-2">
                                @Html.LabelFor(w => w.StartDate)
                                @(Html.KendoDatePickerFor(w => w.StartDate)
                                                                                                    .HtmlAttributes(new { @class = "form-control", style = "width:100%" })
                                                                                                    .Format("dd-MMM-yyyy")
                                                                                                    .Render())
                            </div>
                            <div class="col-md-2">
                                @Html.LabelFor(w => w.EndDate)
                                @(Html.KendoDatePickerFor(w => w.EndDate)
                                                                                                            .HtmlAttributes(new { @class = "form-control", style = "width:100%" })
                                                                                                            .Format("dd-MMM-yyyy")
                                                                                                            .Render())
                            </div>
                            <div class="col-md-2" style="padding-top:22px">
                                <button id="AddAttach" type="button" title="Add Attachment" style="padding: 11px;"
                                        class="btn btn-primary">
                                    <i class="fa fa-plus-circle"></i>
                                </button>
                            </div>
                        </div>
                        <div class="row form-group">
                            <div class="col-md-12">
                                <b id="idErrorMessage" style="color:red;font-weight: 200;margin-left: -14px;"></b>
                            </div>
                        </div>
                        <div class="row form-group @(Model.CustomerDocumentDetail != null ? "" : "hidden")">
                            <table id="DocumentDetail" class="table table-bordered table-striped table-nomargin-nopadding">
                                <thead>
                                    <tr>
                                        <th>Document</th>
                                        <th>Attachment</th>
                                        <th>Start date</th>
                                        <th>End date</th>
                                        <th>Link</th>
                                        <th>Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (Model.CustomerDocumentDetail != null)
                                    {
                                        @foreach (var val in Model.CustomerDocumentDetail)
                                        {
                                            <tr data-documentid='@val.DocumentId' data-documentname='@val.DocumentName' data-attid="@val.PictureId" data-attname='@val.AttachmentName' data-startdate="@val.StartDate" data-enddate="@val.EndDate" data-createdlink="@val.CreatedLink">
                                                <td style="vertical-align: middle;">@val.DocumentName</td>
                                                <td style="vertical-align: middle;">@val.AttachmentName</td>
                                                <td style="vertical-align: middle;">@val.StartDate.Value.ToString("dd-MMM-yyyy")</td>
                                                <td style="vertical-align: middle;">@val.EndDate.Value.ToString("dd-MMM-yyyy")</td>
                                                <td style="text-align: center;vertical-align: middle;"><a style="cursor:pointer !important;padding: 9px;" href="@(val.CreatedLink)" onclick="return CopySelectedText(this)" class='btn btn-primary '>Copy Link</a></td>
                                                <td style="text-align: center;vertical-align: middle;"><a onClick='RemoveRowAndHideHeaderGenuine(this);' class='text-danger'><span class='fa fa-remove'></span></a></td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    }

                    <div class="form-row">
                        <div class="col-12">
                            <input type="submit" value="Save" class="btn btn-primary" onclick="return checkValidation()" />
                            @if (Model.Id != null && Model.Id != 0)
                            {
                                <input type="submit" value="Save & Send" id="btnCustomerEmail" class="btn btn-primary" onclick="return checkValidation()" />
                            }
                            <span id="spinner" style="display:none;"><i class="fa fa-spinner"></i></span>
                        </div>
                    </div>

                </form>
                <div>
                    <a asp-action="Index">Back to List</a>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="~/lib/jquery-unobstusive/jquery-unbostrusive.js"></script>
<script src="~/Vendor/Jquery-Popup/js/popup.js"></script>
<script src="~/lib/jquery-validation/dist/jquery.validate.js"></script>
<script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.js"></script>
