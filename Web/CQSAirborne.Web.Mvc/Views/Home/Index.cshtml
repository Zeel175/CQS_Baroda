@using CQSAirborne.Model.Dashboard
@model DashboardModel
@{
    ViewData["Title"] = "Home Page";
    ViewData["PageHeader"] = "Dashboard";

    if(Model != null && Model.ClickablePath != null && Model.ClickablePath.Count() > 0)
    {
        ViewData["CurrentPage"] = Model.ClickablePath?.FirstOrDefault()?.DocFullName ?? Model.ClickablePath?.FirstOrDefault()?.Name;
    }
    else {
        ViewData["CurrentPage"] = "Home";
    }
}

<script src="~/js/gridviewscroll.js"></script>
@*<link href="~/css/web.css" rel="stylesheet" />*@
