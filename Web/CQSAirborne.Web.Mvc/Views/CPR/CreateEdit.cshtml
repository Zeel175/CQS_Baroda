		$('#ProcessOwnerIds').prop('disabled', true);
		$('#RelevantVerticalHeadIds').prop('disabled', true);

		// 🔥 Disable fSelect UI (MAIN FIX)
		$('#ProcessOwnerIds').closest('.fs-wrap').addClass('disabled');
		$('#RelevantVerticalHeadIds').closest('.fs-wrap').addClass('disabled');
	}

		var canEdit = '@(((ViewBag.IsAdmin != null && ViewBag.IsAdmin == true) || (Model != null && Model.RequestedById == currentUserId)) || (Model == null || Model.Id == null || Model.Id == 0))';

	if (canEdit !== 'True') {

