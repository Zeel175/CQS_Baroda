			.prop('disabled', true);

			$('#ApprovalRemarks').prop('disabled', false);
		// Disable fSelect dropdowns (IMPORTANT)
		$('.fs-wrap').addClass('disabled');

	}
	});

	function syncHidden(selectSel, hiddenSel) {
		var vals = $(selectSel).val() || [];
		vals = vals.filter(function (v) { return v !== '0'; });
		$(hiddenSel).val(vals.join(','));
	}
	function selectAllIfNeeded(selectEl) {
		var $sel = $(selectEl), vals = $sel.val() || [];
		if (vals.indexOf('0') >= 0) {
			var all = $sel.find('option').map(function () { return this.value; }).get()
				.filter(function (v) { return v !== '0'; });
			$sel.val(all).trigger('change.fs');
		}
	}

	var submitHandler = () => {

		//debugger;
		$("#ActionRequested").val(collectCheckboxValues("ar"));
		$("#CPRRaisedDueTo").val(collectCheckboxValues("rd"));
		syncHidden('#RelevantVerticalHeadIds', '#RelevantVerticalHeads');
		syncHidden('#ProcessOwnerIds', '#ProcessOwners');
		var ok = true;
		if (!$("#RequestedDate").val()) ok = false;
		if (!$("#Department").val()) ok = false;
		if (!$("#SectionRequiringChange").val()) ok = false;
		if (!$("#ChangeDescription").val()) ok = false;
		if (!$("#ReasonForChange").val()) ok = false;

		if (!$("#CategoryId").val()) ok = false;
		// if (!$("#DocumentId").val()) ok = false;

		var listName = "";
		$("#Documents > tbody > tr").each(function () {
			var Name = $(this).data("name");

			if (listName == "") {
				listName = Name;
			}
			else {
				listName = listName + "," + Name;
			}
		});
		$("#CreateEditCPRForm").prepend("<input type='hidden' name='DocumentFilePath1' value='" + listName + "'>");
		if ($("#CreateEditCPRForm").valid() && ok == true) {
			$("#spinner").show();
			$('.allTimeDisabled').removeAttr("disabled");
			$("#CreateEditCPRForm").submit();
			return true;
		}
		return false;
	}
</script>
<script>

	function uploadFile(event) {

			$("#global-loader").show();

	   // $(event.target).parent().append('<div id="progress-wrp"><div class="progress-bar"></div><div class="status">0%</div></div>');
			$("#global-loader").append('<div id="progress-wrp"><div class="progress-bar"></div><div class="status">0%</div></div>');
		var file = $(event.target)[0].files[0];
		var upload = new Upload(file);

		// maby check size or type here with upload.getSize() and upload.getType()

		// execute upload
		upload.doUpload(event.target);
	};

	var Upload = function (file) {
		this.file = file;
	}

	Upload.prototype.getType = function () {
		return this.file.type;
	};
	Upload.prototype.getSize = function () {
		return this.file.size;
	};
	Upload.prototype.getName = function () {
		return this.file.name;
	};

	Upload.prototype.doUpload = function (file) {
		var that = this;
		var formData = new FormData();

		// add assoc key values, this will be posts values $(event.target)[0].files
		//formData.append("file", this.file, this.getName());
		$.each($(event.target)[0].files, function (index, value) {
			formData.append("file", value,value.name);
		})

		formData.append("upload_file", true);

	  /*  var tempId = $(file).data("tempid");*/
		var folderName = $(file).data("folder");
		var documentName = $(file).data("docid");

		var finalurl = `@Url.Action("UploadDocument1", "CPR")`;
		$.ajax({
			type: "POST",
			url: finalurl,
			xhr: function () {
				var myXhr = $.ajaxSettings.xhr();
				if (myXhr.upload) {
					myXhr.upload.addEventListener('progress', that.progressHandling, false);
				}
				return myXhr;
			},
			success: function (data) {
				// your callback here
				$("#progress-wrp .progress-bar").css("width", "100%");
				$("#progress-wrp .status").text("100%");
				$("#progress-wrp").remove();
				//HideSpinner()
				//file.previousElementSibling.value = 1;
				$("#" + documentName).val(data.filestring);
				$("#" + documentName).prev().find("btnRemoveDoc").removeClass("hidden");
				//$RelativeElement.prev().attr("href", "../../application/DownloadDocuments?filePath=" + data.filePath);

				var pathstr = "";
				var fnStringArray = data.filestring.split(",");
				$.each(fnStringArray, function (index, value) {
					pathstr = pathstr + `<span class="fa fa-download" style="color:#1173b9 !important;padding-right:6px"></span><a target="_blank" style="font-weight:bold" href="../../CPR/DownloadCPRAttachment?FileName=${value}">${value}</a><br />`
				});
				var strAppend = `<div class='docList'>${pathstr}</div>`;

				$("#" + documentName).parent().find(".docList").remove();
				$("#" + documentName).parent().append(strAppend);

				$("#global-loader").hide();

				toastr.success("Document uploaded successfully!");

			},
			error: function (error) {
				that.file=null;
				$("#progress-wrp").remove()
				$("#global-loader").hide();
				swal({
					title: "Oh Snap!",
					text: "Something Went Wrong! Please try to upload file again.",
					icon: "error",
				});
				//$RelativeElement.addClass("hidden");
				// handle error
			},
			async: true,
			data: formData,
			cache: false,
			contentType: false,
			processData: false,
			timeout: 600000
		});
	};

	Upload.prototype.progressHandling = function (event) {
		var percent = 0;
		var position = event.loaded || event.position;
		var total = event.total;
		var progress_bar_id = "#progress-wrp";
		if (event.lengthComputable) {
			percent = Math.ceil(position / total * 99);
		}
		// update progressbars classes so it fits your code
		$(progress_bar_id + " .progress-bar").css("width", +percent + "%");
		$(progress_bar_id + " .status").text(percent + "%");
	};

	function FileNameIsValid(str) {
		var regex = new RegExp(/[~`!#$%\^&*+=\-\[\]\\';,/{}|\\":<>\?]/);
		return regex.test(str);
	}

	$("#addUploadFile").click(function () {

		if ($('#FileProcessMessage')[0].files.length == 0) {
			$('#FileProcessMessage').siblings('span').html('Please Upload File.');
		}
		else {
			$('#FileProcessMessage').siblings('span').html('');
		}


		var fd = new FormData();
		var files = $('#FileProcessMessage')[0].files[0];

		// var valid = FileNameIsValid(files.name);
		// if (valid == true) {
		// 	$('#FileProcessMessage').siblings('span').html('File name should not contain any special charactor.');
		// 	return;
		// }

		if (files.name != null && files.name != undefined && files.name.indexOf(',') > 0) {
			$('#FileProcessMessage').siblings('span').html('File name should not contain the comma within name.');
			return;
		}
		else {
			$('#FileProcessMessage').siblings('span').html('');
		}

		fd.append('file', files);
		fd.append("upload_file", true);

		$("#spinner").show();

		$.ajax({
			url: '../../CPR/UploadDocument1',
			type: 'post',
			data: fd,
			contentType: false,
			processData: false,
			success: function (response) {
				if (response != "") {

					var fnStringArray = response.filestring.split(",");

					$("#Documents").parent().removeClass("hidden");

					$.each(fnStringArray, function (index, value) {
						if (value != '') {
							$("#Documents > tbody").append("<tr data-name='" +
								value + "' data-filepath='" + value + "'  >" +
								"<td><a target='_blank' href='../../CPR/DownloadCPRAttachment?FileName=" + value + "'><i class='fa fa-download'></i>" + value + "</a></td>" +
								"<td><a onClick='RemoveRowAndHideHeaderGenuine(this);' style='cursor: pointer;' class='text-danger' ><span class='fa fa-remove'></span></a></td></tr>");
						}
					});
					$('#FileProcessMessage').val('');
				}
				else {
					alert('file not uploaded');
				}

				$("#spinner").hide();
			},
			error: function () {
				$("#spinner").hide();
			}
		});

	});

	function RemoveRowAndHideHeaderGenuine(id) {
		var $table = $(id).parents("table");
		$(id).closest("tr").remove();
		if ($table.find("tbody").find("tr").length == 0) {
			$table.parent().addClass("hidden");
		}
	};


</script>
<script>
	(function () {

		const updateUrl = '@Url.Action("UpdateStageStatus", "CPR")';
		const cprId = @Model.Id;

		// Constants from backend (mirror your C# constants)
		const Status = {
			Open: 9,
			Awaiting_Approval: 10,
			Approved: 11,
			Rejected: 12
		};

		$("#btnApprove").on("click", function () {
			sendAction(Status.Approved, false);
		});

		$("#btnReject").on("click", function () {
			sendAction(Status.Rejected, false);
		});

		$("#btnApproveByAdmin").on("click", function () {
			sendAction(Status.Approved, true);
		});

		$("#btnRejectByAdmin").on("click", function () {
			sendAction(Status.Rejected, true);
		});

		function sendAction(requestedStatusId, isFromAdminSide) {
			$("#approveSpinner").show();
			const model = {
				CPRId: cprId,
				RequestedStatusId: requestedStatusId,
				Remarks: $("#ApprovalRemarks").val(),
				AdminRemarks: $("#AdminRemarks").val(),
				IsFromAdminSide: isFromAdminSide,
				EDC: $('#EDC').val(),
				ADC: $('#ADC').val(),
				IsClosed: $('#IsClosed').prop('checked')
			};
			//debugger;
			$.ajax({
				url: updateUrl,
				type: "POST",
				data: JSON.stringify(model), // Convert to JSON string
				contentType: "application/json; charset=utf-8",
				success: function () {
					$("#approveSpinner").hide();
					Swal.fire({
						icon: 'success',
						title: 'Done',
						text: 'Action completed successfully.'
					}).then(() => window.location.reload());
				},
				error: function () {
					$("#approveSpinner").hide();
					Swal.fire({
						icon: 'error',
						title: 'Oops',
						text: 'Failed to perform action. Please try again.'
					});
				}
			});
		}

	})();
</script>
<script>
	$(document).ready(function() {

		// Handle plant change
		$("#PlantId").on("change", function () {
			debugger;
			var plantId = $(this).val();
			if (!plantId) {
				// clear both if no plant selected
				clearEmployeeDropdowns();
				return;
			}

			$.ajax({
				url: '@Url.Action("GetEmployeesByPlant", "CPR")', // or EmployeeController if used there
				type: 'GET',
				data: { plantId: plantId },
				success: function (response) {
					if (response && response.data) {
						// repopulate both dropdowns
						populateEmployeeMultiSelect("#ProcessOwnerIds", response.data);
						populateEmployeeMultiSelect("#RelevantVerticalHeadIds", response.data);
					}
				},
				error: function () {
					toastr.error("Failed to load employees for selected plant.");
				}
			});
		});

		function clearEmployeeDropdowns() {
			$("#ProcessOwnerIds").empty().append('<option value="">Select</option>');
			$("#RelevantVerticalHeadIds").empty().append('<option value="">Select</option>');
			$("#ProcessOwnerIds, #RelevantVerticalHeadIds").trigger('change.fs'); // refresh multiselect UI
			$('.multiselect').fSelect('reload');
		}

		function populateEmployeeMultiSelect(selectId, data) {
			var $select = $(selectId);
			$select.empty();
			$select.append('<option id="select2All" value="0">Select All</option>');
			$.each(data, function (i, emp) {
				$select.append('<option value="' + emp.id + '">' + emp.employeeName + '</option>');
			});
			$select.trigger('change.fs'); // refresh fSelect plugin
			syncHidden(selectId, selectId.replace("Ids", "")); // keep hidden in sync
			$('.multiselect').fSelect('reload');
		}


	});
</script>
