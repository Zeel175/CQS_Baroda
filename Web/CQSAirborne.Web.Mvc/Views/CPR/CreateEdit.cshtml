@using CQSAirborne.Web.Infrastructure.Helpers.Dropdown
@using CQSAirborne.Web.Infrastructure.Helpers.DatePicker
@using CQSAirborne.Model.Core;
@using CQSAirborne.Model.CPRMaster;

@model CQSAirborne.Model.CPRMaster.CPRMasterModel
@{
	ViewData["Title"] = "Create/Edit CPR";
	ViewData["CurrentPage"] = "CPR Master";

	// Safety guards
	var currentUserId = ViewBag.CurrentUserId is int v ? v : 0;

	string rvhCsv = Model?.RelevantVerticalHeads ?? ""; // "1,5,9"
	string poCsv = Model?.ProcessOwners ?? "";

	bool iAmRVH = !string.IsNullOrWhiteSpace(rvhCsv)
						&& rvhCsv.Split(',').Any(x => x.Trim() == currentUserId.ToString());
	bool iAmPO = !string.IsNullOrWhiteSpace(poCsv)
						&& poCsv.Split(',').Any(x => x.Trim() == currentUserId.ToString());

	bool isAwaiting = (Model?.StatusId ?? 0) == Constants.CPRStatusType.Awaiting_Approval;
	bool isApproved = (Model?.StatusId ?? 0) == Constants.CPRStatusType.Approved;
	var approvalModel = ViewBag.ApprovalDetails != null ? (ViewBag.ApprovalDetails) as List<CPRApprovalDetailsModel> : null;

	bool pendingForMe =
		isAwaiting &&
		(
			((Model?.StageId ?? 0) == Constants.CPRStage.Level_I && iAmPO) ||
			((Model?.StageId ?? 0) == Constants.CPRStage.Level_II && iAmRVH)
		);

	bool isRequestedUser = Model != null && Model.RequestedById != null && (currentUserId == Model.RequestedById) ? true : false;

	bool isAdmin = ViewBag.IsAdmin != null && ViewBag.IsAdmin == true;
	bool canEditCPR = isAdmin || isRequestedUser || (Model == null || Model.Id == 0);
}

<link href="~/Vendor/Jquery-Popup/css/popup.css" rel="stylesheet" />
@*@(await Html.PartialAsync("~/Views/Shared/Components/PopupWindow/_PopupWindowPartial.cshtml"))*@

<style>
	.input-validation-error {
		border: none !important;
		border-bottom: 1px solid #dc3545 !important;
	}

	.hide-table-info {
		margin-top: 10px;
	}

	.fs-wrap.disabled {
		pointer-events: none;
		opacity: 0.6;
		background: #f5f5f5;
	}
</style>

<div class="row">
	<div class="col-md-12">
		<div class="card">
			<div class="card-header card-header-primary card-header-container">
				<h4 class="card-title ">Manage Company Procedure Review</h4>
			</div>

			<div class="card-body">
				<form asp-action="CreateEdit" asp-controller="CPR" enctype="multipart/form-data"
					  data-ajax="true" id="CreateEditCPRForm"
					  data-ajax-method="POST" data-ajax-success="onSuccess"
					  data-ajax-failure="onFailed" data-ajax-loading="#spinner"
					  data-ajax-complete="onComplete">

					<div class="validation-summary-errors" id="ModelStateError"></div>
					@Html.AntiForgeryToken()

					<input type="hidden" asp-for="Id" />
					<input type="hidden" asp-for="RequestedById" />
					<input type="hidden" asp-for="ActionRequested" id="ActionRequested" />
					<input type="hidden" asp-for="CPRRaisedDueTo" id="CPRRaisedDueTo" />
					<input type="hidden" asp-for="SessionId" id="SessionId" />

					<!-- Category / Document -->
					<div class="form-row" style="margin-top:15px;">
						@if (Model != null && Model.Id != null && Model.Id > 0)
						{
							<div class="col-md-3">
								<label class="form-control-label">CPR Unique No.</label>
								<input type="text" asp-for="CPRUniqueCode" class="form-control allTimeDisabled" />
							</div>
						}
					</div>
					<div class="form-row">
						<div class="col-md-6">
							<label class="form-control-label">Category<span class="text-danger">*</span></label>
							@(Html.KendoDropDownListFor(w => w.CategoryId)
														.Read(Url.Action("GetAllCategory", "Category"))
														.DataTextField("name")
														.DataValueField("id")
														.OptionLabel("Select Category..")
														.HtmlAttributes(new { @class = "form-control", style = "width: 100%" })
														.Render())
							@Html.ValidationMessageFor(w => w.CategoryId)
						</div>
						<div class="col-md-6">
							<label class="form-control-label">Document@* <span class="text-danger">*</span> *@</label>
							@(Html.KendoDropDownListFor(w => w.DocumentId)
														.Read(Url.Action("GetAllDocumentList", "Document"))
														.DataTextField("name")
														.DataValueField("id")
														.OptionLabel("Select Document..")
														.Filter("Contains")
														.HtmlAttributes(new { @class = "form-control", style = "width: 100%" })
														.Render())
							@* @Html.ValidationMessageFor(w => w.DocumentId) *@
						</div>
					</div>

					<!-- Requested / CPR No / Dept Title -->
					<div class="form-row">
						<div class="col-md-3">
							<label class="form-control-label">Document No</label>
							<input type="text" asp-for="ManualDocumentNo" class="form-control" />
						</div>
						<div class="col-md-3">
							<label class="form-control-label">Request Date<span class="text-danger">*</span></label>
							@(Html.KendoDatePickerFor(w => w.RequestedDate)
														.HtmlAttributes(new { @class = "form-control", style = "width:100%" })
														.Format("dd-MMM-yyyy")
														.Render())
							@Html.ValidationMessageFor(w => w.RequestedDate)
						</div>
						@*<div class="col-md-3">
                                <label class="form-control-label">CPR No (by QA)</label>
                                <input type="text" asp-for="CPRNo" class="form-control" />
                            </div>*@
						<div class="col-md-6">
							<label class="form-control-label">Document Title</label>
							<input type="text" asp-for="DepartmentTitle" class="form-control" />
						</div>
					</div>

					<!-- Dept / Rev / Program -->
					<div class="form-row">
						<div class="col-md-3">
							<label class="form-control-label">Plant<span class="text-danger">*</span></label>
							<select asp-for="PlantId" class="form-control " style="width: 100%">
								<option id="" value="">Select Plant</option>
								@if (ViewBag.PlantList != null)
								{
									foreach (var item in ViewBag.PlantList)
									{
										if (Model != null && Model.PlantId != null && Model.PlantId == item.Id)
										{
											<option id="@item.Id" selected value="@item.Id">@item.Code</option>
										}
										else
										{
											<option id="@item.Id" value="@item.Id">@item.Code</option>
										}
									}
								}
							</select>
							@Html.ValidationMessageFor(w => w.PlantId)
						</div>
						<div class="col-md-3">
							<label class="form-control-label">Department</label>
							<input type="text" asp-for="Department" class="form-control" />
						</div>
						<div class="col-md-3">
							<label class="form-control-label">Revision</label>
							<input type="text" asp-for="Revision" class="form-control" />
						</div>
						<div class="col-md-3">
							<label class="form-control-label">Program</label>
							<input type="text" asp-for="Program" class="form-control" />
						</div>

					</div>

					<!-- Action Requested / Raised Due To -->
					<div class="row form-group" style="margin-top:10px;">
						<div class="col-md-6">
							<h5 style="font-weight: bold;color: #00bcd4;">Action Requested</h5>
							<div class="form-row">
								<div class="col-md-12">
									<label class="mr-3"><input type="checkbox" class="ar" value="New Release" /> New Release</label>
									<label class="mr-3"><input type="checkbox" class="ar" value="Revision" /> Revision</label>
									<label class="mr-3"><input type="checkbox" class="ar" value="Obsolete" /> Obsolete</label>
									<label class="mr-3"><input type="checkbox" class="ar" value="Others" /> Others</label>
								</div>
							</div>
						</div>
						<div class="col-md-6">
							<h5 style="font-weight: bold;color: #00bcd4;">CPR raised due to</h5>
							<div class="form-row">
								<div class="col-md-12">
									<label class="mr-3"><input type="checkbox" class="rd" value="CIB change" /> CIB change</label>
									<label class="mr-3"><input type="checkbox" class="rd" value="Improvement" /> Improvement</label>
									<label class="mr-3"><input type="checkbox" class="rd" value="Audit output" /> Audit output</label>
									<label class="mr-3"><input type="checkbox" class="rd" value="Others" /> Others</label>
								</div>
							</div>
						</div>
					</div>

					<!-- Long text -->
					<div class="form-row">
						<div class="col-md-12">
							<label class="form-control-label">Section Requiring Change</label>
							<textarea asp-for="SectionRequiringChange" class="form-control" rows="2"></textarea>
						</div>
					</div>
					<div class="form-row">
						<div class="col-md-12">
							<label class="form-control-label">Change Description</label>
							<textarea asp-for="ChangeDescription" class="form-control" rows="2"></textarea>
						</div>
					</div>
					<div class="form-row">
						<div class="col-md-12">
							<label class="form-control-label">Reason for Change</label>
							<textarea asp-for="ReasonForChange" class="form-control" rows="2"></textarea>
						</div>
					</div>

					<!-- Dates / Remarks -->
					<div class="form-row">

						<div class="col-md-12">
							<label class="form-control-label">Remarks</label>
							<textarea asp-for="Remarks" class="form-control" rows="2"></textarea>
						</div>
					</div>

					<!-- Manage Approval -->
					<div style="padding: 10px; border: 2px solid #e4dfdf; margin-top: 13px;">
						<div class="form-row">
							<h5 style="font-weight: bold; color: #00bcd4; margin-left: 5px; font-size: 20px;">Manage Approval</h5>
						</div>
						<div class="form-row">

							<div class="col-md-6">
								@Html.LabelFor(w => w.StageId, "Stage")

								<select asp-for="StageId" class="form-control allTimeDisabled" style="width: 100%">
									<option id="0" value="">Select Stage</option>
									@if (ViewBag.StageList != null)
									{
										foreach (var item in ViewBag.StageList)
										{
											if (Model != null && Model.StageId != null && Model.StageId == item.Id)
											{
												<option id="@item.Id" selected value="@item.Id">@item.Name</option>
											}
											else
											{
												<option id="@item.Id" value="@item.Id">@item.Name</option>
											}
										}
									}
								</select>
								@Html.ValidationMessageFor(w => w.StageId)
							</div>

							<div class="col-md-6">
								@Html.LabelFor(w => w.StatusId, "Status")

								<select asp-for="StatusId" class="form-control @(((pendingForMe != null && pendingForMe == true) && isRequestedUser == false) ? "allTimeDisabled" : "")" style="width: 100%">
									<option id="0" value="">Select Status</option>
									@if (ViewBag.StatusList != null)
									{
										foreach (var item in ViewBag.StatusList)
										{
											if (Model != null && Model.StatusId != null && Model.StatusId == item.Id)
											{
												<option id="@item.Id" selected value="@item.Id">@item.Name</option>
											}
											else
											{
												<option id="@item.Id" value="@item.Id">@item.Name</option>
											}
										}
									}
								</select>
								@Html.ValidationMessageFor(w => w.StatusId)
							</div>

							<!-- Process Owner(s) -->
							<div class="col-md-6">
								<label class="form-control-label">Reviewed by</label>
								<input type="hidden" asp-for="ProcessOwners" id="ProcessOwners" />
								@* <select id="ProcessOwnerIds" class="form-control multiselect" multiple="multiple"> *@
								<select id="ProcessOwnerIds" class="form-control multiselect" multiple="multiple" @(isApproved ? "disabled" : "")>
									<option id="select2AllOwners" value="0">Select All</option>
									@if (ViewBag.EmployeeList != null)
									{
										var selectedOwnerIds = (Model != null && !string.IsNullOrWhiteSpace(Model.ProcessOwners))
										? Model.ProcessOwners.Split(",")
										: new string[0];

										foreach (var item in ViewBag.EmployeeList)
										{
											var data = selectedOwnerIds.Any(a => a.ToString().Trim() == item.Id.ToString());
											if (data)
											{
												<option id="@item.Id" selected value="@item.Id">@item.EmployeeName</option>
											}
											else
											{
												<option id="@item.Id" value="@item.Id">@item.EmployeeName</option>
											}
										}
									}
								</select>
							</div>

							<!-- Relevant Vertical Head(s) -->
							<div class="col-md-6">
								<label class="form-control-label">Approved by</label>
								<input type="hidden" asp-for="RelevantVerticalHeads" id="RelevantVerticalHeads" />
								
								@* <select id="RelevantVerticalHeadIds" class="form-control multiselect" multiple="multiple"> *@
								<select id="RelevantVerticalHeadIds" class="form-control multiselect" multiple="multiple" @(isApproved ? "disabled" : "")>
									<option id="select2AllHeads" value="0">Select All</option>
									@if (ViewBag.EmployeeList != null)
									{
										var selectedHeadIds = (Model != null && !string.IsNullOrWhiteSpace(Model.RelevantVerticalHeads))
										? Model.RelevantVerticalHeads.Split(",")
										: new string[0];

										foreach (var item in ViewBag.EmployeeList)
										{
											var data = selectedHeadIds.Any(a => a.ToString().Trim() == item.Id.ToString());
											if (data)
											{
												<option id="@item.Id" selected value="@item.Id">@item.EmployeeName</option>
											}
											else
											{
												<option id="@item.Id" value="@item.Id">@item.EmployeeName</option>
											}
										}
									}
								</select>
							</div>


						</div>
					</div>

					<!-- Attachments (single area: upload + one grid for both saved and session files) -->
					<div style="padding: 10px; border: 2px solid #e4dfdf; margin-top: 13px; margin-bottom: 15px;">
						<div class="row form-group">
							<div class="col-md-12">
								<h4 style="font-weight: bold;color: #00bcd4;font-size: 20px;">Attachments</h4>
								<small>(Uploaded now will appear below immediately. Existing files are preloaded into the same list.)</small>
							</div>
						</div>

						<div class="row form-group">

							<div class="col-md-6">
								<div class="form-group">
									<input type="file" id="FileProcessMessage" name="DocumentDetails" style="z-index: 1; opacity: 1; min-height: 38px; padding: 6px; font-size: 16px; " class="form-control" />
									<span data-validation="FileMessage" class="text-danger"></span>
								</div>
							</div>
							<div class="col-md-6" style="padding-top:0px">
								@if (canEditCPR)
								{
									<button id="addUploadFile" type="button" title="Upload Documents" class="btn btn-primary btn-sm">
										Upload
									</button>
								}
							@* 	<button id="addUploadFile" type="button" title="Upload Documents" style="padding: 12px;"
										class="btn btn-primary btn-sm">
									Upload
								</button> *@
							</div>
							<div class="row form-group col-md-6 @(Model.DocumentFilePath != null ? "" : "hidden")">
								<table id="Documents" style="margin-left: 11px;" class="table table-bordered table-striped table-nomargin-nopadding">
									<thead>
										<tr>
											<th>Documents</th>
											<th>Action</th>
										</tr>
									</thead>
									<tbody>
										@if (Model.DocumentFilePath != null)
										{
											var list = Model.DocumentFilePath.Split(',');
											@foreach (var li in list)
											{
												<tr data-name='@li' data-filepath="@li">
													<td><a target="_blank" href="../../CPR/DownloadCPRAttachment?FileName=@(li)"><i class="fa fa-download"></i> @li</a></td>
													<td>
														@* <a onClick='RemoveRowAndHideHeaderGenuine(this);' style='cursor: pointer;' class='text-danger'><span class='fa fa-remove'></span></a> *@
														@if (canEditCPR)
														{
															<a onClick='RemoveRowAndHideHeaderGenuine(this);' style='cursor: pointer;' class='text-danger'>
																<span class='fa fa-remove'></span>
															</a>
														}
													</td>
												</tr>
											}
										}
									</tbody>
								</table>
							</div>
						</div>
						<div class="row form-group hidden">
							<div class="col-md-6">
								<div class="form-group">
									@Html.HiddenFor(w => w.DocumentFilePath)
								</div>
							</div>
						</div>
					</div>

					@if ((ViewBag.IsAdmin != null && ViewBag.IsAdmin == true) &&
										(Model != null && Model.StatusId != null && Model.StatusId == Constants.CPRStatusType.Approved))
					{
						<div style="padding: 10px; border: 2px solid #e4dfdf; margin-top: 13px; margin-bottom: 15px;">
							<div class="row form-group">
								<div class="col-md-12">
									<h4 style="font-weight: bold;color: #00bcd4;font-size: 20px;">QMS Admin Approval</h4>
								</div>
							</div>
							<div class="form-row" style="margin-left: 0px;">
								<div class="col-md-3">
									@Html.LabelFor(w => w.EDC, "EDC")
									@(Html.KendoDatePickerFor(w => w.EDC)
																.HtmlAttributes(new { @class = "form-control", style = "width:100%" })
																.Format("dd-MMM-yyyy")
																.Render())
								</div>
								<div class="col-md-3">
									@Html.LabelFor(w => w.ADC, "ADC")
									@(Html.KendoDatePickerFor(w => w.ADC)
																.HtmlAttributes(new { @class = "form-control", style = "width:100%" })
																.Format("dd-MMM-yyyy")
																.Render())
								</div>
							</div>

							<div class="form-row" style="margin-left: 0px;">
								<div class="col-md-12" style="padding: 11px 14px 0px; margin-top: 14px; margin-bottom: 6px; background: aliceblue; border-radius: 8px;">
									<label class="mr-3" style="color: #09b6cc;">
										<input type="checkbox" asp-for="IsClosed" class="csGroup" />
										Do you want to close this application?
									</label>
								</div>
							</div>

							<div class="form-row @(Model.AdminStatusId == Constants.CPRStatusType.Approved || Model.AdminStatusId == Constants.CPRStatusType.Rejected ? "hidden": "")">
								<div class="col-md-12" style="margin-top: 13px;">
									<div class="form-group">
										<label asp-for="AdminRemarks">Remarks (optional)</label>
										<textarea asp-for="AdminRemarks" class="form-control" rows="2" placeholder="Add any note for this action..."></textarea>
									</div>

								</div>
								
								<div class="col-md-12">
									<button type="button" id="btnApproveByAdmin" class="btn btn-success mr-2">
										<i class="fa fa-check mr-1"></i> Accept &amp; Release
									</button>
									<button type="button" id="btnRejectByAdmin" class="btn btn-danger">
										<i class="fa fa-times mr-1"></i> Reject &amp; Revert
									</button>
									<span id="approveSpinner" class="ml-2" style="display:none;"><i class="fa fa-spinner fa-spin"></i></span>
								</div>
							</div>
						</div>
					}
					@* @if (!pendingForMe && Model.IsClosed != true) *@
					@if (!pendingForMe && Model.IsClosed != true && canEditCPR)
					{
						<div class="form-row">
							<div class="col-md-12">
								<input type="button" value="Save" class="btn btn-primary" onclick="return submitHandler()" />
								<span id="spinner" style="display:none;"><i class="fa fa-spinner"></i></span>
							</div>
						</div>
					}

					<div class="form-row">
						@if (pendingForMe)
						{
							<div id="approvalPanel" class="card mt-3">
								<div class="card-header" style="background:#f6f9ff">
									<strong>Approval pending for you</strong>
									<span class="badge badge-info ml-2">
										@(Model.StageId == Constants.CPRStage.Level_I ? "Level I (Reviewed by)" : "Level II (Approved by)")
									</span>
								</div>
								<div class="card-body">
									<div class="form-group">
										<label for="ApprovalRemarks">Remarks (optional)</label>
										<textarea id="ApprovalRemarks" class="form-control" rows="2" placeholder="Add any note for this action..."></textarea>
									</div>

									<div>
										<button type="button" id="btnApprove" class="btn btn-success mr-2">
											<i class="fa fa-check mr-1"></i> Approve
										</button>
										<button type="button" id="btnReject" class="btn btn-danger">
											<i class="fa fa-times mr-1"></i> Reject
										</button>
										<span id="approveSpinner" class="ml-2" style="display:none;"><i class="fa fa-spinner fa-spin"></i></span>
									</div>

									<small class="text-muted d-block mt-2">
										• Approve at Level I moves request to Level II (Awaiting Approval).<br />
										• Approve at Level II marks request as Approved. Reject keeps current level and marks as Rejected.
									</small>
								</div>
							</div>
						}
					</div>

					@if (approvalModel != null && approvalModel.Count() > 0)
					{
						<div style="padding: 10px; border: 2px solid #e4dfdf; margin-top: 13px; margin-bottom: 15px;">
							<div class="form-row">
								<div class="col-md-12">
									<div style="background: aliceblue;padding: 0px 10px;border-radius: 5px;">
										<h4 style="font-weight: bold;color: #00bcd4;font-size: 19px;padding: 4px;margin-top:15px;">Approval History</h4>
									</div>
									<table class="table table-bordered table-striped table-nomargin-nopadding">
										<thead>
											<tr>
												<th>Level</th>
												<th>Send To</th>
												<th>Action</th>
												<th>Approved/Rejected By</th>
												<th>Remarks</th>
												<th>Date</th>
											</tr>
										</thead>
										<tbody>
											@foreach (var item in approvalModel)
											{
												<tr>
													<td>
														@* @(item.StageId == Constants.CPRStage.Level_I ? "Level I (Reviewed by)" : "Level II (Approved by)") *@
														@(item.Stage)
													</td>
													<td>@item.EmployeeName</td>
													<td>
														@(item.Status)
													</td>
													<td>@item.Approver</td>
													<td>@item.ApproverRemarks</td>
													<td>@item.StatusDateTime?.ToString("dd-MMM-yyyy HH:mm")</td>
												</tr>
											}
										</tbody>
									</table>
								</div>
							</div>
						</div>
					}
				</form>

				<div class="mt-3">
