@using System.Net
@using CQSAirborne.Model.Core
@model CQSAirborne.Model.CPRMaster.CPRPrintModel
@{
	Layout = null;
	// string fmt(DateTime? d) => d.HasValue ? d.Value.ToString("dd-MM-yyyy hh:mm tt") : "";
	// string fmt1(DateTime? d) => d.HasValue ? d.Value.ToString("dd-MM-yyyy") : "";

	string fmt(DateTime? d)
			=> d.HasValue ? d.Value.ToString("dd-MM-yyyy hh:mm tt") : "";

	string fmt1(DateTime? d)
		=> d.HasValue ? d.Value.ToString("dd-MM-yyyy") : "";

	var l1 = Model.Level1Approvals?.FirstOrDefault(); // if you already have this shape
	bool isApproved = (Model.StatusName ?? "").Equals("Approved", StringComparison.OrdinalIgnoreCase);
	bool isRejected = (Model.StatusName ?? "").Equals("Rejected", StringComparison.OrdinalIgnoreCase);
	var reqDate = l1?.CreatedDate ?? Model.CreatedDate;
	if ((Model.StatusName ?? "").Equals("Closed", StringComparison.OrdinalIgnoreCase) == true)
	{
		isApproved = true;
	}

	// string br(string s) => WebUtility.HtmlEncode(s ?? "")
	//   .Replace("\r\n", "<br/>").Replace("\n", "<br/>");

	string br(string s)
		=> WebUtility.HtmlEncode(s ?? "")
						.Replace("\r\n", "<br/>")
						.Replace("\n", "<br/>");

	string IconFor(string fileName)
	{
		var ext = System.IO.Path.GetExtension(fileName ?? "").ToLowerInvariant();
		switch (ext)
		{
			case ".pdf": return Url.Content("~/pdf-icons/pdf.png");
			case ".doc":
			case ".docx": return Url.Content("~/pdf-icons/word.png");
			case ".xls":
			case ".xlsx": return Url.Content("~/pdf-icons/excel.png");
			case ".logo": return Url.Content("~/pdf-icons/logo.png");
			default: return Url.Content("~/pdf-icons/file.png");
		}
	}
}
<!DOCTYPE html>
<html>
<head>
	<meta charset="utf-8" />
	<title>QMS - CPR - @Model.CPRNo</title>

	<style>
		.approval-grid {
		width: 100% !important;
		border-collapse: collapse;
		table-layout: fixed;
		}

		.approval-grid td {
		border: 1px solid #333;
		padding: 6px 8px;
		vertical-align: top;
		padding-left: 3px;
		}

		.sec-title {
		font-weight: 600;
		white-space: nowrap;
		}

		.customWrap {
		text-wrap: auto !important;
		word-wrap: break-word !important;
		}

		.center {
		text-align: center;
		}


		.w-edc {
		width: 6%;
		}

		.w-adc {
		width: 8%;
		}

		.w-qa {
		width: 8%;
		}

		.w-qa2 {
		width: 8%;
		}

		.w-qa3 {
		width: 10%;
		}

		.check {
		display: inline-block;
		width: 12px;
		height: 12px;
		border: 1px solid #333;
		vertical-align: middle;
		}

		.check.checked {
		background: #222;
		}


		.approval-grid .sec-title {
		font-weight: 600;
		white-space: nowrap;
		}

		.approval-grid .center {
		text-align: center;
		}

		.approval-grid .w-role {
		width: 22%;
		}

		.approval-grid .w-name {
		width: 18%;
		}

		.approval-grid .w-sign {
		width: 12%;
		}

		.approval-grid .w-date {
		width: 12%;
		}

		.approval-grid .w-accrej {
		width: 14%;
		}

		.approval-grid .w-remarks {
		width: auto;
		}

		.approval-grid .w-edc,
		.approval-grid .w-adc,
		.approval-grid .w-qa {
		width: 8%;
		text-align: center;
		}

		.check {
		display: inline-block;
		width: 14px;
		height: 14px;
		border: 1px solid #000;
		border-radius: 2px;
		margin-right: 6px;
		vertical-align: middle;
		}

		.check.checked::after {
		content: "✓";
		font-weight: 700;
		font-size: 12px;
		position: relative;
		top: -2px;
		}

		.muted {
		color: #444;
		text-wrap: auto;
		word-wrap: break-word;
		}
	</style>
	<style>
		* {
		box-sizing: border-box;
		font-family: Arial, Helvetica, sans-serif;
		}

		body {
		font-size: 12px;
		}

		h2 {
		text-align: center;
		margin: 6px 0 10px;
		font-size: 18px;
		font-weight: 700;
		}

		table {
		width: 100%;
		border-collapse: collapse;
		}

		td, th {
		border: 1px solid #999;
		padding: 6px 8px;
		vertical-align: top;
		padding-left: 3px;
		}

		.no-b {
		border: none !important;
		}

		.muted {
		color: #666;
		font-size: 11px;
		}

		.label {
		width: 180px;
		background: #f4f4f4;
		font-weight: 600;
		}

		.sec-title {
		background: #f4f4f4;
		font-weight: 700;
		}


		.w-15 {
		width: 15%
		}

		.w-17 {
		width: 17%
		}

		.w-20 {
		width: 20%
		}

		.w-25 {
		width: 25%
		}

		.w-30 {
		width: 30%
		}

		.w-35 {
		width: 35%
		}

		.w-40 {
		width: 40%
		}

		.check {
		display: inline-block;
		width: 12px;
		height: 12px;
		border: 1px solid #000;
		margin-right: 6px;
		}

		.checked {
		background: #000;
		}

		.col {
		display: inline-block;
		margin-right: 18px;
		}

		.watermark {
		position: fixed;
		top: 45%;
		left: 10%;
		right: 10%;
		text-align: center;
		opacity: 0.08;
		font-size: 72px;
		transform: rotate(-35deg);
		z-index: 0;
		pointer-events: none;
		font-weight: 800;
		letter-spacing: 10px;
		/* ✅ Add prefixed transforms for wkhtmltopdf compatibility */
		-webkit-transform: rotate(-35deg);
		-moz-transform: rotate(-35deg);
		-o-transform: rotate(-35deg);
		transform: rotate(-35deg);
		/* Also set transform-origin for better control */
		-webkit-transform-origin: center center;
		transform-origin: center center;
		}

		.small {
		font-size: 11px;
		}

		.attachments li {
		margin: 2px 0;
		}
	</style>

	<style>
		.att {
		text-align: center;
		margin: 14px 0;
		}

		.att img {
		width: 36px;
		height: 36px;
		display: block;
		margin: 0 auto 6px;
		}

		.att .name {
		max-width: 150px;
		word-wrap: break-word;
		margin: 0 auto;
		}
	</style>
	<style>
		.pdf-header {
		display: table;
		width: 100%;
		border-collapse: collapse;
		margin-bottom: 8px;
		}

		.pdf-header .cell {
		display: table-cell;
		vertical-align: middle;
		}

		.pdf-header .left {
		width: 160px;
		}

		.pdf-header .center {
		text-align: center;
		font-size: 20px;
		font-weight: 700;
		}

		.pdf-header .leftAlign {
		text-align: left;
		color: #0a8f2d;
		font-weight: 600;
		padding-bottom: 25px;
		}

		.pdf-header img {
		height: 42px;
		}
	</style>
</head>
<body>

	<div class="watermark">CONFIDENTIAL</div>


	<div class="pdf-header">
		<div class="cell leftAlign">
			TASL Open
		</div>
	</div>
	<div class="pdf-header">
		<div class="cell left">
			<img src="@IconFor("logo.logo")" alt="TASL">
		</div>
		<div class="cell center">
			COMPANY PROCEDURE REVIEW (CPR)
		</div>

	</div>

	<table>
		<tr>
			<td class="sec-title w-17">Document Category<br /><span class="muted">CPD / QM / OM / SOP / OI / POI / Forms / Others</span></td>
			<td class="">@Model.CategoryName</td>
			<td class="sec-title">Document<br /> No.</td>
			<td class="">@Model.DocumentNo</td>
			<td class="sec-title">Request<br /> Date</td>
			<td class="">@fmt1(Model.RequestedDate)</td>
			<td class="sec-title">CPR No.<br /><span class="muted">To be filled by QMS</span></td>
			<td class="">@Model.CPRNo</td>
		</tr>
		<tr>
			<td class="sec-title w-17">Document Title</td>
			<td class="" colspan="3">@Model.DepartmentTitle</td>
			<td class="sec-title w-10">Department</td>
			<td>@Model.Department</td>
			<td class="sec-title">Document<br /> Revision</td>
			<td>@Model.Revision</td>
		</tr>
		<tr>
			<td class="sec-title w-17">CPR Requested by</td>
			<td class="" colspan="3">@Model.RequestedByName</td>
			<td class="sec-title ">Program</td>
			<td class="" colspan="3">@Model.Program</td>
		</tr>
		<tr>
			<td class="sec-title w-17">Action Requested</td>
			<td class="w-17" colspan="2">
				<span class="col"><span class="check @(Model.IsNewRelease ? " checked":"")"></span>New Release</span>
				<span class="col"><span class="check @(Model.IsRevision ? " checked":"")"></span>Revision</span>
				<span class="col"><span class="check @(Model.IsObsolete ? " checked":"")"></span>Obsolete</span>
				<span class="col"><span class="check @(Model.IsOtherAction ? " checked":"")"></span>Others</span>
			</td>
			<td class="sec-title ">CPR raised<br /> due to</td>
			<td class="w-17" colspan="2">
				<div><span class="check @(Model.DueToCibChange ? " checked":"")"></span>CIB change</div>
				<div><span class="check @(Model.DueToImprovement ? " checked":"")"></span>Improvement</div>
				<div><span class="check @(Model.DueToAuditOutput ? " checked":"")"></span>Audit output</div>
				<div><span class="check @(Model.DueToOther ? " checked":"")"></span>Others</div>
			</td>

			<td class="" colspan="2">
				<div style="font-weight:600;">Attachments:</div>
				<ul class="attachments">
					@foreach (var a in Model.Attachments)
					{
						<div class="att">
							<img src="@IconFor(a.FileName)" alt="">
							@* <div class="name">@a.DisplayName</div> *@
							<a href="@a.DownloadUrl" style="color:black;text-decoration:none;" target="_blank">
								@a.DisplayName
							</a>

						</div>
					}
				</ul>
			</td>
			@* 	<td colspan="2">
				<div style="font-weight:600;">Attachments:</div>
				<ul class="attachments">
					@foreach (var a in Model.Attachments)
					{
						<li class="att">
							<img src="@IconFor(a.FileName)" alt="">

							<a class="name"
							   href="@Url.Action("DownloadCPRAttachment", "CPR", new { FileName = a.FileName })"
							   target="_blank">
								@a.DisplayName
							</a>

						</li>
					}
				</ul>
			</td> *@

		</tr>
		<tr>
			<td class="sec-title w-17">Section Requiring Change<br /><span class="muted small">State the clause/line item/page no.or <br />any other keyword, as applicable</span></td>
			<td colspan="7">@Html.Raw(br(Model.SectionRequiringChange))</td>
		</tr>
		<tr>
			<td class="sec-title">Change Description<br /><span class="muted small">Brief the change requirement</span></td>
			<td colspan="7">@Html.Raw(br(Model.ChangeDescription))</td>
		</tr>
		<tr>
			<td class="sec-title">Reason for Change<br /><span class="muted small">Validate the change requirement</span></td>
			<td colspan="7">@Html.Raw(br(Model.ReasonForChange))</td>
		</tr>
	</table>

	<table class="approval-grid">
		<colgroup>
			<col class="w-role" />
			<col class="w-name" />
			<col class="w-sign" />
			<col class="w-date" />
			<col class="w-accrej" />
			<col class="w-remarks" />
			<col class="w-edc" />
			<col class="w-adc" />
			<col class="w-qa" />
			<col class="w-qa2" />
			<col class="w-qa3" />
		</colgroup>

		<!-- Row 1: Requestor -->
		<tr>
			<td class="sec-title customWrap">CPR Requestor/Prepared by</td>
			<td>
				<div><span class="sec-title">Name:</span></div>
				<div>- @Model.RequestedByName</div>
			</td>
			<td>
				<div style="font-weight:600;">Sign:</div>
			</td>
			<td>
				<div style="font-weight:600;">Date:</div>
				<div>@fmt(reqDate)</div>
			</td>

			<!-- Accept/Reject spans rows 1–2 -->
			<td rowspan="2" class="center">
				<div>
					<span class="check @(isApproved ? "checked" : "")"></span>
					<span class="sec-title">Accepted</span>
				</div>
				<div style="margin-top:10px;">
					<span class="check @(isRejected ? "checked" : "")"></span>
					<span class="sec-title">Rejected</span>
				</div>
			</td>

			<!-- Remarks spans all 3 rows -->
			<td rowspan="3">
				<div class="sec-title">Remarks:</div>
				<div class="muted">@Model.Remarks</div>
			</td>

			<!-- Reserve space for EDC/ADC/QA (columns 7–11) -->
			<td colspan="5"></td>
		</tr>

		<!-- Row 2: Level I -->
		<tr>
			<td class="sec-title customWrap">Reviewed by</td>
			<td>
				<div style="font-weight:600;">Name:</div>
				@if (Model.StatusId == Constants.CPRStatusType.Approved || Model.StatusId == Constants.CPRStatusType.Rejected)
				{
					<div>- @Model.Level1Approvals?.FirstOrDefault()?.ApprovedByUser</div>
				}
				else
				{
					if (!string.IsNullOrWhiteSpace(Model.ProcessOwnerNames))
					{
						foreach (var nm in Model.ProcessOwnerNames
						.Split(',')
						.Select(s => s.Trim())
						.Where(s => s.Length > 0))
						{
							<div>- @nm</div>
						}
					}
				}
			</td>
			<td><div style="font-weight:600;">Sign:</div></td>
			<td>
				<div style="font-weight:600;">Date:</div>
				<div>
					@if (Model.Level1Approvals != null && Model.Level1Approvals.Count() > 0)
					{
						@fmt(Model.Level1Approvals?.LastOrDefault().StatusDateTime)
					}
				</div>
			</td>

			<!-- Placeholder for the last 5 columns -->
			<td colspan="5"></td>
		</tr>

		<!-- Row 3: Level II + EDC/ADC/QA -->
		<tr>
			<td class="sec-title customWrap">Approved by</td>
			<td>
				<div style="font-weight:600;">Name:</div>
				@if (Model.StatusId == Constants.CPRStatusType.Approved || Model.StatusId == Constants.CPRStatusType.Rejected)
				{
					<div>- @Model.Level2Approvals?.FirstOrDefault()?.ApprovedByUser</div>
				}
				else
				{
					@if (!string.IsNullOrWhiteSpace(Model.RelevantVerticalHeadNames))
					{
						foreach (var nm in Model.RelevantVerticalHeadNames.Split(',').Select(s => s.Trim()).Where(s => s.Length > 0))
						{
							<div>- @nm</div>
						}
					}
				}
			</td>
			<td><div style="font-weight:600;">Sign:</div></td>
			<td>
				<div style="font-weight:600;">Date:</div>
				<div>
					@if (Model.Level2Approvals != null && Model.Level2Approvals.Count() > 0)
					{
						@fmt(Model.Level2Approvals?.LastOrDefault().StatusDateTime)
					}
				</div>
			</td>

			<!-- Now show the last 4 columns -->
			<td class="sec-title center">EDC</td>
			<td class="center" style="font-size: 10px;padding-right:3px">@fmt1(Model.EDC)</td>
			<td class="sec-title center">ADC</td>
			<td class="center" style="font-size: 10px; padding-right: 3px ">@fmt1(Model.ADC)</td>
			<td class="sec-title center customWrap">QMS Sign</td>
			<td class="center">
				@if (@Model.QMSAdmin != null && @Model.QMSAdmin != "")
				{
					<div>- @Model.QMSAdmin</div>
				}
				@* @if (@Model.ClosedDate != null && @Model.ClosedDate != DateTime.MinValue)
				{
					<div>- @Model.ClosedDate</div>
				}
				else *@ 
				@if (@Model.AdminStatusDate != null && @Model.AdminStatusDate != DateTime.MinValue)
				{
				<div>- @Model.AdminStatusDate</div>
				}
			</td>
		</tr>
	</table>

	<div class="muted" style="margin-top:8px;">
		<em>Note: This is a computer generated document and does not require a physical signature.</em>
	</div>

</body>
</html>
