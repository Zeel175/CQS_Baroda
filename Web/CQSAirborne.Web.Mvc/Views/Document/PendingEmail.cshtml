@using CQSAirborne.Web.Infrastructure.Helpers.DatePicker

@model CQSAirborne.Model.Core.DataSourceRequest
@using System.Security.Claims
@using CQSAirborne.Web.Mvc.Utils
@{
    ViewData["Title"] = "Email Documents";
    ViewData["CurrentPage"] = "EmailDocuments";
    ViewData["PageHeader"] = "Email Documents";
}
<script src="~/js/document.js"></script>
<link href="~/Vendor/Jquery-Popup/css/popup.css" rel="stylesheet" />
<script src="~/pendingemailrelated/bootstrap.min.js"></script>
<link href="~/pendingemailrelated/bootstrap.min.css" rel="stylesheet" />

<style>
    use {
        pointer-events: none;
    }
    /*.tblclass {
        white-space: nowrap;
        word-break:break-word;
        width:150%;
    }*/
    .selected {
        background-color: #dee4ef !important;
    }

    .email-preview-container {
        padding: 10px;
    }

    .preview-section {
        margin-bottom: 20px;
    }

        .preview-section label {
            font-weight: 600;
            color: #555;
            margin-bottom: 5px;
            display: block;
        }

    .preview-box {
        background: #f8f9fb;
        border: 1px solid #ddd;
        padding: 10px;
        border-radius: 6px;
    }

    /* Gmail-style chips */
    .recipient-container {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        background: #f8f9fb;
        border: 1px solid #ddd;
        padding: 10px;
        border-radius: 6px;
        max-height: 120px;
        overflow-y: auto;
    }

    .recipient-chip {
        background: #e3f2fd;
        color: #0d47a1;
        padding: 5px 10px;
        border-radius: 20px;
        font-size: 13px;
        display: inline-flex;
        align-items: center;
    }

    /* Table styling */
    .custom-table thead {
        background-color: #17a2b8;
        color: white;
    }

    .custom-table th {
        text-align: center;
    }

    .custom-table td {
        vertical-align: middle;
    }

    .email-card {
        background: #ffffff;
        border: 1px solid #e0e0e0;
        border-radius: 8px;
        padding: 15px;
        margin-bottom: 10px;
        box-shadow: 0 2px 6px rgba(0,0,0,0.05);
    }

    .email-separator {
        border-top: 2px dashed #ccc;
        margin: 25px 0;
    }

    .preview-section {
        margin-bottom: 20px;
    }

        .preview-section label {
            font-weight: 600;
            color: #555;
            margin-bottom: 5px;
            display: block;
        }

    .preview-box {
        background: #f8f9fb;
        border: 1px solid #ddd;
        padding: 10px;
        border-radius: 6px;
    }

    .recipient-container {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        background: #f8f9fb;
        border: 1px solid #ddd;
        padding: 10px;
        border-radius: 6px;
        max-height: 120px;
        overflow-y: auto;
    }

    .recipient-chip {
        background: #e3f2fd;
        color: #0d47a1;
        padding: 6px 12px;
        border-radius: 20px;
        font-size: 13px;
        cursor: move;
        user-select: none;
    }

        .recipient-chip:hover {
            background: #bbdefb;
        }

    .custom-table thead {
        background-color: #17a2b8;
        color: white;
    }

    .custom-table th {
        text-align: center;
    }

    .custom-table td {
        vertical-align: middle;
    }
</style>
@(await Html.PartialAsync("~/Views/Shared/Components/PopupWindow/_PopupWindowPartial.cshtml"))
<div class="row">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header card-header-primary card-header-container">
                <h4 class="card-title ">Email Documents</h4>
            </div>
            <div class="card-body">
                <div class="form-row">
                    <div class="col-md-3">
                        @Html.Label(null,"Date")
                        @(Html.KendoDatePickerFor(w => w.RevisionDate).HtmlAttributes(new { @class = "form-control", @style = "width:100%" }).Format("dd-MMM-yyyy").Render())
                    </div>
                    <div class="col-md-3"></div>
                    <div class="col-md-6">
                        @Html.Label(null, "Mail Subject")
                        @Html.TextBoxFor(w => w.CustomFilter, new { @class = "form-control", @style = "width:90%" })
                    </div>
                </div>
                <div class="form-row" style="margin-top: 12px; margin-bottom: 12px;">
                    <div class="col-6">
                        <input type="button" value="Preview" class="btn btn-primary btnPreview" />
                    </div>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table id="pendingDocumentGrid" class="table table-bordered" cellspacing="0" cellpadding="5" width="100%">
                            <thead class="text-primary">
                                <tr>
                                    <th class="text-center sorting_disabled" style="vertical-align:middle;"><input name="select_all" value="1" type="checkbox"></th>
                                    <th style="vertical-align:middle;">Doc. Unique No</th>
                                    <th style="vertical-align:middle;">Doc. Name</th>
                                    <th style="vertical-align:middle;">Plant Name</th>
                                    <th style="vertical-align:middle;">Rev. No.</th>
                                    <th style="vertical-align:middle;">Rev. Date</th>
                                    <th style="vertical-align:middle;">Doc. Type</th>
                                    <th style="vertical-align:middle;">Process Owner</th>
                                </tr>
                            </thead>
                        </table>
                    </div>
                    <div class="form-row" style="margin-top: 12px; margin-bottom: 12px;">
                        <div class="col-md-12 text-center">

                            <input type="button" value="Preview Mail" class="btn btn-primary btnPreviewEmail" />
                            <input type="button" value="Send Mail" class="btn btn-primary btnSendMail" />
                            
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-12">
                <div id="processingModel" class="modal text-center transparent" role="dialog" style="background-color: rgba(255,255,255,0.7);z-index:9999;">
                    <div style="margin-top:15%">
                        <img src="~/assets/img/loader.gif" style="width: 10%;" />
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<div class="modal fade" id="emailPreviewModal" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-xl" role="document" style="max-width: 90%;">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Email Preview</h5>
                <button type="button" class="close" data-dismiss="modal">
                    <span>&times;</span>
                </button>
            </div>

            <div class="modal-body" id="previewContent" style="max-height:70vh; overflow:auto;">
                <!-- Preview content will come here -->
            </div>

            <div class="modal-footer">
                <button class="btn btn-success" onclick="confirmSendMail()">Send Mail</button>
                <button class="btn btn-danger" data-dismiss="modal">Close</button>
            </div>

        </div>
    </div>
</div>
<script>
  
    var exportDataObj = {};
    var rows_selected = [];
    // var dataUrl = '@Url.Action("GetPendingEmailDocuments", "Document")';
    var dataUrl = '@Url.Action("GetPendingEmailDocumentsBySP", "Document")';
    var grid;
    $(document).ready(function () {
        GridBind();


        // Updates "Select all" control in a data table
        //
        function updateDataTableSelectAllCtrl(grid) {
            var $table = grid.table().node();
            var $chkbox_all = $('tbody input[type="checkbox"]', $table);
            var $chkbox_checked = $('tbody input[type="checkbox"]:checked', $table);
            var chkbox_select_all = $('thead input[name="select_all"]', $table).get(0);

            // If none of the checkboxes are checked
            if ($chkbox_checked.length === 0) {
                chkbox_select_all.checked = false;
                if ('indeterminate' in chkbox_select_all) {
                    chkbox_select_all.indeterminate = false;
                }

                // If all of the checkboxes are checked
            } else if ($chkbox_checked.length === $chkbox_all.length) {
                chkbox_select_all.checked = true;
                if ('indeterminate' in chkbox_select_all) {
                    chkbox_select_all.indeterminate = false;
                }

                // If some of the checkboxes are checked
            } else {
                chkbox_select_all.checked = true;
                if ('indeterminate' in chkbox_select_all) {
                    chkbox_select_all.indeterminate = true;
                }
            }
        }

        // Handle click on checkbox
        $('#pendingDocumentGrid tbody').on('click', 'input[type="checkbox"]', function (e) {
            var $row = $(this).closest('tr');

            // Get row data
            var data = grid.row($row).data();

            // Get row ID
            var rowId = data.id;

            // Determine whether row ID is in the list of selected row IDs 
            var index = $.inArray(rowId, rows_selected);

            // If checkbox is checked and row ID is not in list of selected row IDs
            if (this.checked && index === -1) {
                rows_selected.push(rowId);

                // Otherwise, if checkbox is not checked and row ID is in list of selected row IDs
            } else if (!this.checked && index !== -1) {
                rows_selected.splice(index, 1);
            }

            if (this.checked) {
                $row.addClass('selected');
            } else {
                $row.removeClass('selected');
            }

            // Update state of "Select all" control
            updateDataTableSelectAllCtrl(grid);

            // Prevent click event from propagating to parent
            e.stopPropagation();
        });

        // Handle click on table cells with checkboxes
        $('#pendingDocumentGrid').on('click', 'tbody td, thead th:first-child', function (e) {
            $(this).parent().find('input[type="checkbox"]').trigger('click');
        });

        // Handle click on "Select all" control
        $('thead input[name="select_all"]', grid.table().container()).on('click', function (e) {
            if (this.checked) {
                $('#pendingDocumentGrid tbody input[type="checkbox"]:not(:checked)').trigger('click');
            } else {
                $('#pendingDocumentGrid tbody input[type="checkbox"]:checked').trigger('click');
            }

            // Prevent click event from propagating to parent
            e.stopPropagation();
        });

        // Handle table draw event
        grid.on('draw', function () {
            // Update state of "Select all" control
            updateDataTableSelectAllCtrl(grid);
        });

    });

    function GridBind() {

        //debugger;
        var exportDataObj = {
            RevisionDate: $("#RevisionDate").val()
        };

        var columns = [
            { "data": null, "searchable": false, "orderable": false },
            { "data": "documentNumber", "searchable": true, "orderable": false },
            { "data": "documentName", "searchable": true, "orderable": false },
            { "data": "plantName", "searchable": true, "orderable": false },
            { "data": "revisionNumber", "searchable": true, "orderable": false },
            { "data": "revisionDate", "searchable": true, "orderable": false },
            { "data": "documentType", "searchable": true, "orderable": false },
            { "data": "processOwner", "searchable": true, "orderable": false }
        ];

        try {
            grid = $('#pendingDocumentGrid').DataTable();
            grid.destroy();
        }
        catch (e) { }

        grid = $('#pendingDocumentGrid').DataTable({
            "searching": true,
            "processing": true,
            "serverSide": false,
            "pageLength": 100,
            "scrollX": true,
            "scrollY": '450px',
            "scrollCollapse": true,
            "columnDefs": [{
                "targets": 0,
                "searchable": false,
                "orderable": false,
                "width": 70,
                "className":"text-center sorting_disabled",
                "render": function (data, type, full, meta) {
                    //debugger;
                    return '<input style="vertical-align:middle;" data-id="'+data.id+'" type="checkbox">';
                }},
                {
                    "width": 160,
                    targets: 1
                },
                {
                    "width":290,
                    targets: 2
                },
                {
                    "width": 140,
                    targets: 3
                },
                {
                    "width": 90,
                    targets: 4
                },
                {
                    "width": 90,
                    targets: 5
                },
                {
                    "width": 90,
                    targets: 6
                }, 
                {
                    "width": 140,
                    targets: 7
                }],
            "columns": columns,
            "ajax": {
                "url": dataUrl,
                "type": "POST",
                "data": function (d) {
                    $.extend(d, exportDataObj);
                },
                "error": function (xhr, error, code) {
                    //debugger;
                    if (code == "Unauthorized") {
                        Swal.fire({
                            title: 'Session Expired!',
                            icon: 'error',
                            showCancelButton: false,
                            confirmButtonColor: '#3085d6',
                            confirmButtonText: 'Ok',
                            allowEscapeKey: true
                        }).then((result) => {
                            if (result.value) {
                                logoutWeb('@Url.Action("LogOut", "Account")');
                            }
                            if (result.dismiss === Swal.DismissReason.timer) {
                                logoutWeb('@Url.Action("LogOut", "Account")');
                            }
                        })
                    }
                }
            }
        });

    }
</script>
<script src="~/lib/jquery-unobstusive/jquery-unbostrusive.js"></script>
<script src="~/Vendor/Jquery-Popup/js/popup.js"></script>
<script>
    $(".btnPreview").click(function () {
        GridBind();
    });
    
    var statusUrl = '@Url.Action("SendPendingEmail", "Document")'
    $(".btnSendMail").click(function () {
        debugger;
        var pendingIds = "";
        $.each(rows_selected, function (index, rowId) {
            // Create a hidden element
            if (rowId != null && rowId != undefined) {
                if (pendingIds == "") {
                    pendingIds = rowId;
                }
                else {
                    pendingIds = pendingIds + ',' + rowId;
                }
            }
        });
        debugger;
        var title = $('#CustomFilter').val();
        if (pendingIds != "") {
            var obj = {
                ids: pendingIds,
                title: title
            }

            $.ajax({
                type: 'POST',
                url: statusUrl,
                data: obj,
                success: function (response) {
                    $('#processingModel').modal('hide');
                    if (response.status == true) {
                        md.showNotification('Send Successfully', 'success')
                        $('#CustomFilter').val('');
                        GridBind();
                    } else {
                        md.showNotification('Something went wrong. Please try again', 'danger')
                    }
                }
            })
        }
        else {
            md.showNotification('Please select atleast one document.', 'danger')
        }
    });
</script>
<script>

    var previewUrl = '@Url.Action("PreviewEmail", "Document")';
        $(".btnPreviewEmail").click(function () {
            debugger;
        var pendingIds = "";

        $.each(rows_selected, function (index, rowId) {
            if (rowId != null && rowId != undefined) {
                if (pendingIds == "") {
                    pendingIds = rowId;
                } else {
                    pendingIds = pendingIds + ',' + rowId;
                }
            }
        });

        var title = $('#CustomFilter').val();

        if (pendingIds == "") {
            md.showNotification('Please select atleast one document.', 'danger');
            return;
        }

        var obj = {
            ids: pendingIds,
            title: title
        };

        $("#processingModel").modal('show');

        $.ajax({
            type: 'POST',
            url: previewUrl,
            data: obj,
            success: function (response) {
                $("#processingModel").modal('hide');

                if (response && response.length > 0) {
                    renderPreviewPopup(response);
                } else {
                    md.showNotification('No preview data found.', 'danger');
                }
            },
            error: function () {
                $("#processingModel").modal('hide');
                md.showNotification('Error while loading preview.', 'danger');
            }
        });
    });


               function renderPreviewPopup(data) {

        var html = "";

        $.each(data, function (i, item) {

            // ===== Email Card Start =====
            html += "<div class='email-card'>";

            // Subject
            html += "<div class='preview-section'>";
            html += "<label>Subject</label>";
            html += "<div class='preview-box'>" + item.subject + "</div>";
            html += "</div>";

            // Recipients (Draggable Chips)
            html += "<div class='preview-section'>";
            html += "<label>Recipients</label>";
            html += "<div class='recipient-container draggable-recipients'>";

            $.each(item.recipients, function (j, email) {
                html += "<span class='recipient-chip'>" + email + "</span>";
            });

            html += "</div>";
            html += "</div>";

            // Documents Table
            html += "<div class='preview-section'>";
            html += "<label>Documents</label>";

            html += "<div class='table-responsive'>";
            html += "<table class='table table-hover table-bordered custom-table'>";
            html += "<thead>";
            html += "<tr>";
            html += "<th>Doc No</th>";
            html += "<th>Name</th>";
            html += "<th>Revision</th>";
            html += "<th>Type</th>";
            html += "</tr>";
            html += "</thead><tbody>";

            $.each(item.documents, function (j, doc) {
                html += "<tr>";
                html += "<td>" + doc.documentNumber + "</td>";
                html += "<td>" + doc.documentName + "</td>";
                html += "<td>" + doc.revisionNo + "</td>";
                html += "<td>" + (doc.documentType || "") + "</td>";
                html += "</tr>";
            });

            html += "</tbody></table>";
            html += "</div>";

            html += "</div>"; // section
            html += "</div>"; // email-card

            // ===== Separator between multiple emails =====
            if (i < data.length - 1) {
                html += "<hr class='email-separator'/>";
            }
        });

        // Inject HTML
        $("#previewContent").html(html);

        // Show modal
        $("#emailPreviewModal").modal('show');

        // Enable draggable recipients
        setTimeout(function () {
            $(".draggable-recipients").sortable({
                items: ".recipient-chip",
                cursor: "move",
                opacity: 0.7,
                containment: "parent",
                tolerance: "pointer"
            });
        }, 200);
    }

        function confirmSendMail() {
        $("#emailPreviewModal").modal('hide');
        $(".btnSendMail").click();
    }

</script>
