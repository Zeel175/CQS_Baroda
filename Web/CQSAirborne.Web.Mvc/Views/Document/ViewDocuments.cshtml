@using CQSAirborne.Web.Infrastructure.Helpers.DatePicker
@using CQSAirborne.Web.Infrastructure.Helpers.Dropdown

@model CQSAirborne.Model.Document.DocumentListDataModel
@using System.Security.Claims
@using CQSAirborne.Web.Mvc.Utils
@{
    ViewData["Title"] = "MasterPCFTracker";
    ViewData["CurrentPage"] = "MasterPCFTracker";
    ViewData["PageHeader"] = "Master PCF Tracker";
}
<script src="~/js/document.js"></script>
<link href="~/Vendor/Jquery-Popup/css/popup.css" rel="stylesheet" />
<style>
    use {
        pointer-events: none;
    }
    /*.tblclass {
        white-space: nowrap;
        word-break:break-word;
        width:150%;
    }*/
</style>
@(await Html.PartialAsync("~/Views/Shared/Components/PopupWindow/_PopupWindowPartial.cshtml"))
<div class="row">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header card-header-primary card-header-container">
                <h4 class="card-title ">Master PCF Tracker</h4>
            </div>
            <div class="card-body">

                <div class="form-row">
                    <div class="col-6">
                        @Html.Label(null, "Status")
                        @(Html.KendoDropDownListFor(w => w.StatusId)
                                                .Read(Url.Action("GetAllActiveStatus", "Document"))
                                                .DataTextField("name")
                                                .DataValueField("id")
                                                //.OptionLabel("All")
                                                //.OnChange("onDocumentStatusChange")
                                                .HtmlAttributes(new { @class = "form-control", style = "width: 100%" })
                                                .Render())
                    </div>

                    <div class="col-6">
                        @Html.Label(null, "Document Type")
                        @(Html.KendoDropDownListFor(w => w.DocumentTypeId)
                                                .Read(Url.Action("GetAllPrefixDocNumber", "Document"))
                                                .DataTextField("name")
                                                .DataValueField("name")
                                                .OptionLabel("All")
                                                .OnChange("onDocumentTypeChange")
                                                .HtmlAttributes(new { @class = "form-control", style = "width: 100%" })
                                                .Render())
                    </div>
                </div>
                <div class="form-row" style="display:none">
                    <div class="col-6">
                        @Html.LabelFor(w => w.RevisionDate)
                        @(Html.KendoDatePickerFor(w => w.RevisionDate).HtmlAttributes(new { @class = "form-control", @style = "width:100%" }).Format("dd-MMM-yyyy").Render())
                    </div>
                </div>
                <div class="form-row" style="margin-top: 12px; margin-bottom: 12px;">
                    <div class="col-6">
                        <input type="button" value="Preview" class="btn btn-primary btnPreview" />
                    </div>
                    <div class="col-6 text-right" id="divExport">
                        <button id="btnExport" type="button" style="display:none" data-for="1" value="Export Pdf" class="btn btn-success btnExport"><i class="fa fa-file-pdf-o" aria-hidden="true" style="margin-right:5px;"></i>Export Pdf</button>
                        <button id="btnExport" type="button" data-for="2" value="Export Excel" class="btn btn-success btnExport"><i class="fa fa-file-excel-o" aria-hidden="true" style="margin-right:5px;"></i>Export Excel</button>
                    </div>
                </div>

                <div class="table-responsive">
                    <table id="example" class="table table-striped table-bordered nowrap" cellspacing="0" cellpadding="5" width="100">
                        <thead class="text-primary">
                            <tr>
                                <th style="vertical-align:middle;">Status</th>
                                <th style="vertical-align:middle;">Doc. Type</th>
                                <th style="vertical-align:middle;">Doc. Unique No.</th>
                                <th style="vertical-align:middle;">Document Name</th>
                                <th style="white-space:normal;text-wrap:normal;vertical-align:middle;">Revision No.</th>
                                <th style="vertical-align:middle;">Revision Date</th>
                                <th style="vertical-align:middle;">Inactive Date</th>

                                <!-- moved up -->
                                <th style="vertical-align:middle;">CPR Reference Number</th>
                                <th style="vertical-align:middle;">Reason for Change</th>

                                @foreach (var plant in Model.Plants)
                                {
                                    <th style="vertical-align:middle;">@plant.Code</th>
                                }
                                <th style="vertical-align:middle;">Process Owner</th>
                                <th style="vertical-align:middle;">Remarks</th>
                            </tr>
                        </thead>
                    </table>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-12">
                <div id="processingModel" class="modal text-center transparent" role="dialog" style="background-color: rgba(255,255,255,0.7);z-index:9999;">
                    <div style="margin-top:15%">
                        <img src="~/assets/img/loader.gif" style="width: 10%;" />
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    var exportDataObj = {};
    @*var dataUrl = '@Url.Action("GetDocumentMasterTrackerData", "Document")';*@
    var dataUrl = '@Url.Action("GetAllForExportWithSP", "Document")';
    var statusUrl = '@Url.Action("ChangeStatus", "Document")'
    var statusConfirmMsg = 'Are you sure you want to change the status of this document?';
    var grid;
    //debugger;
    $(document).ready(function () {
        var plants = JSON.parse('@Html.Raw(Json.Serialize(Model.Plants))');
        plants = _.sortBy(plants, "displayOrder");
        var columns = [
            {
                data: "isActive",
                mRender: function (data, type, row) {
                    return "<span>" + (row.isActive ? "Active" : "InActive") + "</span>";
                },
                searchable: false
            },
            { data: "docTypePrefix" },
            { data: "documentNumber" },
            { data: "name" },
            { data: "revisionNumber" },     // Latest Revision No.
            { data: "revisionDate" },
            { data: "inActiveDt" },

            // moved up
            { data: "cprNumber" },          // CPR Reference Number
            { data: "reasonForChange" }     // Reason for Change
        ];


        $.each(plants, function (i, v) {
            columns.push({
                "data": null,
                "searchable": false,
                "orderable": false,

                "mRender": function (data, type, row) {
                    var documentPlant = row.plants.filter(function (w) {
                        return w.plantId == v.id;
                    })[0];

                    if (documentPlant != null && documentPlant != undefined) {
                        debugger;
                        var template = kendo.template($("#view-download-template").html());
                        var documentType = (row.documentTypeCode == '@CQSAirborne.Model.Core.Constants.DocumentType.Global') ? @((int)CQSAirborne.Model.Core.DocumentOperationType.Common) : @((int)CQSAirborne.Model.Core.DocumentOperationType.Document);
                        return template({ displayName: documentPlant.documentDisplayName, id: documentPlant.id, canDownload: documentPlant.canDownload, documentType: documentType  });
                        //return "<span class='fa fa-check'></span>";
                    }

                    return "";
                }
            });
        });
        // now these come after plant columns
        columns.push({ data: "processOwner" });
        columns.push({ data: "remarks" });

        grid = $('#example').DataTable({
            "searching": false,
            "processing": true,
            "serverSide": true,
            "pageLength": 100,
            "scrollX": true,
            "scrollY": '450px',
            "scrollCollapse": true,
            "columns": columns,
            "columnDefs": [
                { width: 200, targets: 0 },
            ],
            "ajax": {
                "url": dataUrl,
                "type": "POST",
                "data": function (d) {
                    exportDataObj = d;

                },
                "error": function (xhr, error, code) {
                    //debugger;
                    if (code == "Unauthorized") {
                        Swal.fire({
                            title: 'Session Expired!',
                            icon: 'error',
                            showCancelButton: false,
                            confirmButtonColor: '#3085d6',
                            confirmButtonText: 'Ok',
                            allowEscapeKey: true
                        }).then((result) => {
                            if (result.value) {
                                logoutWeb('@Url.Action("LogOut", "Account")');
                            }
                            if (result.dismiss === Swal.DismissReason.timer) {
                                logoutWeb('@Url.Action("LogOut", "Account")');
                            }
                        })
                    }
                }
            }
        });
    });
</script>
<script>
       $(".btnExport").click(function () {
           //debugger;
           $("#processingModel").show();

           var exportDataObj = {
               //RevisionDate: $("#RevisionDate").val(),
               StatusId: $("#StatusId").val(),
               DocTypePrefix: $("#DocumentTypeId").val(),
               CustomFilter: "2"
           };

            var linkFor = $(this).attr("data-for");

           $.post("@Url.Action("ViewDocumentsForExport", "Document")", exportDataObj, function (result) {
               //debugger;
                $("#processingModel").hide();
                if (result.fileStatus == true) {
                    window.open(result.filePath, "_blank");
                }
            });

        });
</script>
<script>
    $(".btnPreview").click(function () {
        //debugger;

        var exportDataObj = {
            //RevisionDate: $("#RevisionDate").val(),
            StatusId: $("#StatusId").val(),
            DocTypePrefix: $("#DocumentTypeId").val()
        };
    @*var dataUrl = '@Url.Action("GetDocumentMasterTrackerData", "Document")';*@
        var dataUrl = '@Url.Action("GetAllForExportWithSP", "Document")';
    var statusUrl = '@Url.Action("ChangeStatus", "Document")'
    var statusConfirmMsg = 'Are you sure you want to change the status of this document?';
    var grid;
        var plants = JSON.parse('@Html.Raw(Json.Serialize(Model.Plants))');
        plants = _.sortBy(plants, "displayOrder");
        var columns = [
            {
                data: "isActive",
                mRender: function (data, type, row) {
                    return "<span>" + (row.isActive ? "Active" : "InActive") + "</span>";
                },
                searchable: false
            },
            { data: "docTypePrefix" },
            { data: "documentNumber" },
            { data: "name" },
            { data: "revisionNumber" },     // Latest Revision No.
            { data: "revisionDate" },
            { data: "inActiveDt" },

            // moved up
            { data: "cprNumber" },          // CPR Reference Number
            { data: "reasonForChange" }     // Reason for Change
        ];


        $.each(plants, function (i, v) {
            columns.push({
                "data": null,
                "searchable": false,
                "orderable": false,

                "mRender": function (data, type, row) {
                    var documentPlant = row.plants.filter(function (w) {
                        return w.plantId == v.id;
                    })[0];

                    if (documentPlant != null && documentPlant != undefined) {
                        var template = kendo.template($("#view-download-template").html());
                        var documentType = (row.documentTypeCode == '@CQSAirborne.Model.Core.Constants.DocumentType.Global') ? @((int)CQSAirborne.Model.Core.DocumentOperationType.Common) : @((int)CQSAirborne.Model.Core.DocumentOperationType.Document);
                        return template({ displayName: documentPlant.documentDisplayName, id: documentPlant.id, canDownload: documentPlant.canDownload, documentType: documentType  });
                        //return "<span class='fa fa-check'></span>";
                    }

                    return "";
                }
            });
        });
        // now these come after plant columns
        columns.push({ data: "processOwner" });
        columns.push({ data: "remarks" });

        try {
            grid = $('#example').DataTable();
            grid.destroy();
        }
        catch (e) { }

        grid = $('#example').DataTable({
            "searching": false,
            "processing": true,
            "serverSide": true,
            "pageLength": 100,
            "scrollX": true,
            "scrollY": '450px',
            "scrollCollapse": true,
            "columns": columns,
            "columnDefs": [
                { width: 200, targets: 0 },
            ],
            "ajax": {
                "url": dataUrl,
                "type": "POST",
                "data": function (d) {
                    $.extend(d, exportDataObj);
                }
            }
        });

    });
</script>
<script type="text/html" id="view-download-template">
    <div class="btn-group">
        <button class="btn btn-secondary btn-sm dropdown-toggle dashboard-grid-fix-button" type="button" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
            #=displayName#
        </button>
        <div class="dropdown-menu">
            <a class="dropdown-item" target="_blank" href='/Home/ViewDocument/#:id#/#:documentType#'>View</a>
            #if(canDownload == true){#
            <a class="dropdown-item" download target='_blank' href='/Home/DownloadDocument/#:id#/#:documentType#'>Download</a>
            #}#
        </div>
    </div>
</script>
