@model CQSAirborne.Model.Document.DocumentListDataModel
@using System.Security.Claims
@using CQSAirborne.Web.Mvc.Utils
@{
    ViewData["Title"] = "Document";
    ViewData["CurrentPage"] = "Document";
    ViewData["PageHeader"] = "Document";
}
<link href="~/css/bootstrap-toggle.min.css" rel="stylesheet" />
<link href="~/Vendor/Jquery-Popup/css/popup.css" rel="stylesheet" />

<style>
    /* ===== sizing for frozen columns (tune as needed) ===== */
    :root {
        --col-1: 130px; /* Doc. Unique No. */
        --col-2: 230px; /* Document Name   */
        --col-3: 70px; /* Rev. No.        */
        --col-4: 120px; /* Upload Date */
        --col-5: 120px; /* CPR Ref */
        --col-6: 230px; /* Category */

        --cell-py: 10px;
        --cell-px: 12px;
        --cell-lh: 1.35;
        --head-bg: #00a9b9;
        --head-color: #fff;
    }

    /* scroll container for the TABLE only (DataTables injects this via `dom`) */
    .datatable-wrap {
        max-height: 520px;
        overflow: auto; /* both axes */
        position: relative;
        border: 1px solid #e7e7e7;
        border-radius: 6px;
        background: #fff;
    }

    /* tidy control bars (not scrollable) */
    .dt-top {
        margin-bottom: .5rem;
    }

    .dt-bottom {
        margin-top: .5rem;
    }

    /* single table; let it be wider than the viewport */
    #example {
        width: max-content; /* expands to fit content/cols */
        min-width: 100%;
        border-collapse: separate !important;
        border-spacing: 0;
    }

        /* unified cell metrics + wrap */
        #example th, #example td {
            padding: var(--cell-py) var(--cell-px) !important;
            line-height: var(--cell-lh) !important;
            white-space: normal !important;
            word-break: break-word;
            text-align: left !important;
            vertical-align: middle;
            background-clip: padding-box;
        }

        /* header styling + sticky */
        #example thead th {
            background: var(--head-bg);
            color: var(--head-color);
            position: sticky;
            top: 0;
            z-index: 3;
        }

        /* borders */
        #example th, #example td {
            border-right: 1px solid #e7e7e7;
            border-bottom: 1px solid #e7e7e7;
        }

            #example th:first-child, #example td:first-child {
                border-left: 1px solid #e7e7e7;
            }

            /* widths for first 4 columns */
            #example th.freeze-1, #example td.freeze-1 {
                width: var(--col-1);
                min-width: var(--col-1);
                max-width: var(--col-1);
            }

            #example th.freeze-2, #example td.freeze-2 {
                width: var(--col-2);
                min-width: var(--col-2);
                max-width: var(--col-2);
            }

            #example th.freeze-3, #example td.freeze-3 {
                width: var(--col-3);
                min-width: var(--col-3);
                max-width: var(--col-3);
            }

            #example th.freeze-4, #example td.freeze-4 {
                width: var(--col-4);
                min-width: var(--col-4);
                max-width: var(--col-4);
            }

            #example th.freeze-5, #example td.freeze-5 {
                width: var(--col-5);
                min-width: var(--col-5);
                max-width: var(--col-5);
            }

            /* sticky left columns (both header & body) */
            #example th.freeze-1, #example td.freeze-1 {
                position: sticky;
                left: 0;
                z-index: 2;
                background: #fff;
            }

            #example th.freeze-2, #example td.freeze-2 {
                position: sticky;
                left: calc(var(--col-1));
                z-index: 2;
                background: #fff;
            }

            #example th.freeze-3, #example td.freeze-3 {
                position: sticky;
                left: calc(var(--col-1) + var(--col-2));
                z-index: 2;
                background: #fff;
            }

            #example th.freeze-4, #example td.freeze-4 {
                position: sticky;
                left: calc(var(--col-1) + var(--col-2) + var(--col-3));
                z-index: 2;
                background: #fff;
                box-shadow: 2px 0 0 rgba(0,0,0,.06);
            }

            #example th.freeze-5, #example td.freeze-5 {
                position: sticky;
                left: calc(var(--col-1) + var(--col-2) + var(--col-3) + var(--col-4));
                z-index: 2;
                background: #fff;
                box-shadow: 2px 0 0 rgba(0,0,0,.06);
            }
            

            #example th.freeze-4, #example td.freeze-4 {
                width: var(--col-4);
                min-width: var(--col-4);
                max-width: var(--col-4);
                position: sticky;
                left: calc(var(--col-1) + var(--col-2) + var(--col-3));
                z-index: 2;
                background: #fff;
            }

            #example th.freeze-5, #example td.freeze-5 {
                width: var(--col-5);
                min-width: var(--col-5);
                max-width: var(--col-5);
                position: sticky;
                left: calc(var(--col-1) + var(--col-2) + var(--col-3) + var(--col-4));
                z-index: 2;
                background: #fff;
            }

            #example th.freeze-6, #example td.freeze-6 {
                width: var(--col-6);
                min-width: var(--col-6);
                max-width: var(--col-6);
                position: sticky;
                left: calc(var(--col-1) + var(--col-2) + var(--col-3) + var(--col-4) + var(--col-5));
                z-index: 2;
                background: #fff;
                box-shadow: 2px 0 0 rgba(0,0,0,.06);
            }


        /* header cells that are also frozen need higher z-index */
        #example thead th.freeze-1,
        #example thead th.freeze-2,
        #example thead th.freeze-3,
        #example thead th.freeze-4 {
            z-index: 4;
        }

        #example thead th.freeze-5,
        #example thead th.freeze-6 {
            z-index: 4;
        }



    /* give key non-frozen columns decent min-width so text doesn't stack vertically */
    td.col-owner, th.col-owner {
        min-width: 100px;
    }

    td.col-status, th.col-status {
        min-width: 80px;
    }

    /* small button tweaks */
    .dashboard-grid-fix-button {
        /*padding: 0 !important;*/
        margin: 0 !important;
        border: 0 !important;
        /*width: 50px;*/
        width: 89px;
        padding: 5px !important;
    }

    td > .btn-group {
        margin: 0 !important;
    }

    td > button {
        padding: 0 6px !important;
    }
</style>

@(await Html.PartialAsync("~/Views/Shared/Components/PopupWindow/_PopupWindowPartial.cshtml"))

<div class="row">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header card-header-primary card-header-container d-flex justify-content-between align-items-center" style="padding: 3px 14px;">
                <h4 class="card-title mb-0">Document List</h4>
                <a href='@Url.Action("Create", "Document")' class="btn btn-warning"><i class="fa fa-plus"></i> Add New</a>
            </div>

            <div class="card-body">
                <!-- No manual wrapper here; DataTables will inject .datatable-wrap via `dom` -->
                <table id="example" class="table table-striped table-bordered" cellspacing="0">
                    <thead>
                        <tr id="tableHeader">
                            <th class="freeze-1">Doc. Unique No.</th>
                            <th class="freeze-2">Document Name</th>
                            <th class="freeze-3">Rev. No.</th>
                            <th class="freeze-4">Upload Date</th>
                            <th class="freeze-5">CPR Ref.</th>
                            <th class="freeze-6">Category</th>


                            <th class="col-owner">Process Owner</th>
                            <th class="col-status">Status</th>
                            @foreach (var plant in Model.Plants)
                            {
                                <th style="min-width:90px; max-width:130px;">@plant.Code</th>
                            }
                            <th style="min-width:120px;">Action</th>
                        </tr>
                    </thead>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Modal -->
<div class="modal" id="myModal">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h4 class="modal-title" style="color:#00bcd4;">Change Document Status</h4>
                <button type="button" class="close" data-dismiss="modal">&times;</button>
            </div>
            <div class="modal-body">
                <div class="row"><div class="col-md-12"><div class="form-group"><label id="AlertMsg" style="color:red;font-weight:bold"></label></div></div></div>
                <div class="row" id="divNotify">
                    <div class="col-md-3 col-xs-6" style="margin-top:12px;">Notification</div>
                    <div class="col-md-9 col-xs-6" id="boxToggle">
                        <input type="checkbox" id="IsNotify" data-toggle="toggle" data-on="Enabled" data-off="Disabled">
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <input type="hidden" id="BoxId" />
                <input type="hidden" id="BoxStatus" />
                <button type="button" class="btn btn-primary" id="btnChangeStatus">Yes</button>
                <button type="button" class="btn btn-default" data-dismiss="modal">No</button>
            </div>
        </div>
    </div>
</div>

<script src="~/js/bootstrap-toggle.min.js"></script>

<script>
  var dataUrl   = '@Url.Action("GetDocumentDataNew","Document")';
  var statusUrl = '@Url.Action("ChangeStatusNew", "Document")';
  var grid;

  $(document).ready(function () {
    var plants = JSON.parse('@Html.Raw(Json.Serialize(Model.Plants))');
    plants = _.sortBy(plants, "displayOrder");

    var columns = [
      { data: "documentNumber"  }, // 0 - freeze-1
      { data: "name"            }, // 1 - freeze-2
         { data: "revisionNumber" }, // 2 - freeze-3
       {                               // 3 ✅ Upload Date
      data: "uploadDate",
      render: function (data, type) {
          if (!data) return "";

          // sorting → return raw date
          if (type === "sort" || type === "type") {
              return data;
          }

          // display → dd-MMM-yyyy
          return moment(data).format("DD-MM-YYYY");
      }
    },

    { data: "cprNumber" },          // 4
    { data: "category" },           // 5
    { data: "processOwner" },       // 6
      {
        data: "isActive",
        searchable: false,
        orderable: false,
        mRender: function (data, type, row) {
          var template = kendo.template($("#active-template-doc").html());
          return template({ id: row.id, isActive: row.isActive });
        }
      }
    ];

    $.each(plants, function (i, v) {
      columns.push({
        data: null,
        searchable: false,
        orderable: false,
        mRender: function (data, type, row) {
          var documentPlant = row.plants.filter(function (w) { return w.plantId == v.id; })[0];
          if (documentPlant != null && documentPlant != undefined) {
            var template = kendo.template($("#view-download-template").html());
            var documentType = (row.documentTypeCode == '@CQSAirborne.Model.Core.Constants.DocumentType.Global')
              ? @((int)CQSAirborne.Model.Core.DocumentOperationType.Common)
              : @((int)CQSAirborne.Model.Core.DocumentOperationType.Document);
            return template({
              displayName: documentPlant.documentDisplayName,
              id: documentPlant.id,
              canDownload: documentPlant.canDownload,
              documentType: documentType
            });
          }
          return "";
        }
      });
    });

    columns.push({
      data: null,
      searchable: false,
      orderable: false,
      className: "center-content",
      mRender: function (data, type, row) {
        return "<a href='/Document/Edit/" + row.id + "'><i class='fa fa-pencil'></i></a>&nbsp"
            + "<a href=\"javascript: onclick=OpenPopupWithUrl('../../Document/EmailDocument/" + row.id + "')\"><i class='fa fa-envelope'></i></a>&nbsp"
             + "<a onclick='DeleteDocument(" + row.id + ")' style='display:@(ViewBag.IsDelete);' href='javascript:void(0)'><i class='fa fa-trash'></i></a>";
      }
    });

    grid = $('#example').DataTable({
      searching: true,
      processing: true,
      serverSide: true,
      pageLength: 100,
      autoWidth: false,
      columns: columns,
      order: [[0, 'asc']],

      // >>> Place controls OUTSIDE the scrolling area; only the table (t) is inside .datatable-wrap
      dom: '<"dt-top d-flex justify-content-between align-items-center"lf>'
         + '<"datatable-wrap"t>'
         + '<"dt-bottom d-flex justify-content-between align-items-center"ip>',

          columnDefs: [
      { targets: 0, className: 'freeze-1' },
      { targets: 1, className: 'freeze-2' },
      { targets: 2, className: 'freeze-3' },
      { targets: 3, className: 'freeze-4' }, // Upload Date
      { targets: 4, className: 'freeze-5' }, // CPR Ref
      { targets: 5, className: 'freeze-6' }, // Category
      { targets: 6, className: 'col-owner' },
      { targets: 7, className: 'col-status' }
    ],

      ajax: {
        url: dataUrl,
        type: "POST",
        error: function (xhr, error, code) {
          if (code === "Unauthorized") {
            Swal.fire({
              title: 'Session Expired!',
              icon: 'error',
              showCancelButton: false,
              confirmButtonColor: '#3085d6',
              confirmButtonText: 'Ok',
              allowEscapeKey: true
            }).then((result) => {
              if (result.value || result.dismiss === Swal.DismissReason.timer) {
                logoutWeb('@Url.Action("LogOut", "Account")');
              }
            });
          }
        }
      }
    });
  });

  function ChangeDocStatus(id, status) {
    $("#BoxId").val(id);
    $("#BoxStatus").val(status);
    if (status == false) {
      $("#divNotify").show();
      $("#AlertMsg").text("Are you sure you want to inactive this document?");
    } else {
      $("#divNotify").hide();
      $("#AlertMsg").text("Are you sure you want to active this document?");
    }
    $('#myModal').modal('show');
  }

  $("#btnChangeStatus").click(function () {
    var IsNotify = $("#IsNotify").prop("checked");
    var obj = { id: $("#BoxId").val(), status: $("#BoxStatus").val(), isNotify: IsNotify };

    $.ajax({
      type: 'POST',
      url: statusUrl,
      data: obj,
      success: function (response) {
        $('#myModal').modal('hide');
        if (response.status === true) {
          md.showNotification('Status changed successfully', 'success');
          grid.ajax.reload(null, false);
        } else {
          md.showNotification('Unable to change the status. Please try again', 'danger');
        }
      }
    });
  });

  function DeleteDocument(id) {
    Swal.fire({
      title: 'Are you sure?',
      text: "You won't be able to revert this!",
      icon: 'warning',
      showCancelButton: true,
      confirmButtonColor: '#3085d6',
      cancelButtonColor: '#d33',
      confirmButtonText: 'Yes, delete it!'
    }).then((result) => {
      if (result.value) {
        $.getJSON("../../Document/Delete/" + id, function () {
          Swal.fire('Deleted!','Your file has been deleted.','success');
          grid.ajax.reload(null, false);
        });
      }
    });
  }
</script>

<script id="active-template-doc" type="text/html">
    #if(isActive==true){#
    <button type="button" class="btn btn-sm btn-success" onclick="ChangeDocStatus(#:id#, false)">Active</button>
    #} else {#
    <button type="button" class="btn btn-sm btn-danger" onclick="ChangeDocStatus(#:id#, true)">Inactive</button>
    #}#
</script>

<script type="text/html" id="view-download-template">
    <div style="width:90px;text-align:center">
        <button class="btn btn-secondary btn-sm dropdown-toggle dashboard-grid-fix-button" type="button" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
            #=displayName#
        </button>
        <div class="dropdown-menu">
            <a class="dropdown-item" target="_blank" href='/Home/ViewDocument/#:id#/#:documentType#'>View</a>
            #if(canDownload == true){#
            <a class="dropdown-item" download target='_blank' href='/Home/DownloadDocument/#:id#/#:documentType#'>Download</a>
            #}#
        </div>
    </div>
</script>

@(await Html.PartialAsync("_CommonListPartial"))
<script src="~/lib/jquery-unobstusive/jquery-unbostrusive.js"></script>
<script src="~/Vendor/Jquery-Popup/js/popup.js"></script>
<script src="~/lib/SweetAlert/SweetAlert.js"></script>
